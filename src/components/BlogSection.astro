---
import type { Translations } from '@/i18n/translations';
import { getRoutes } from '@/configurations/routes';
import Icon from '@/components/shared/Icon.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getPosts } from '@/content/_posts';

interface Props {
  translations: Translations;
}

const { translations: t } = Astro.props;
const routes = getRoutes(Astro.currentLocale);

const allPosts = await getPosts();
const LATEST_COUNT = 6;
const previewPosts = allPosts.slice(0, LATEST_COUNT);
const linkLabel = allPosts.length > LATEST_COUNT ? t['blog.all'] : t['blog.visit'];
---

{previewPosts.length > 0 && (
  <section id="blog" class="uc-section uc-section--soft" aria-labelledby="blog-heading">
    <div class="uc-container">
      <div class="blog-head">
        <div>
          <p class="uc-eyebrow" style="margin-bottom: 16px;">Insights</p>
          <h2 id="blog-heading" class="uc-h2">{t['blog.heading']}</h2>
          <p class="uc-lead" style="margin-top: 16px; max-width: 640px;">{t['blog.subtitle']}</p>
        </div>
        <a href={routes.blog} class="blog-link">
          {linkLabel}
          <Icon name="arrow_outward" class="w-4 h-4" />
        </a>
      </div>

      <div class="uc-grid-3 blog-grid">
        {previewPosts.map((post, index) => (
          <BlogCard post={post} index={index + 1} headingLevel="h3" />
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .blog-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
  }
  .blog-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgb(var(--brand-primary));
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    flex-shrink: 0;
  }
  .blog-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  @media (max-width: 900px) {
    .blog-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
