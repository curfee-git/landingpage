---
import { getRoutes } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();
---

<section
  id="contact"
  class="py-20 sm:py-26 xl:py-36 bg-brand-primary text-brand-primary-foreground"
  aria-labelledby="contact-heading"
>
  <div class="mx-auto px-gutter xl:px-0 text-center max-w-180">
    <h2
      id="contact-heading"
      class="font-sans text-3xl md:text-4xl font-extrabold leading-none tracking-tight text-balance break-words hyphens-auto m-0 text-brand-primary-foreground"
    >
      {t['calltoaction.heading']}
    </h2>
    <p class="text-body-x-large text-surface-base/85 max-w-140 font-medium mt-6 mx-auto">
      {t['calltoaction.subtitle']}
    </p>
    <a
      href={routes.contact}
      class="inline-flex items-center gap-2 mt-8 px-7 py-3.5 font-sans text-base font-bold bg-surface-base text-brand-primary border-2 border-surface-base rounded-md no-underline transition-colors duration-200 hover:bg-surface-base/85"
    >
      {t['hero.cta']}
    </a>
  </div>
</section>
