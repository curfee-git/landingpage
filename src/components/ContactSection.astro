---
import { EXTERNAL } from '@/configurations/routes';

interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
---

<section id="contact" class="py-20 md:py-28" aria-labelledby="contact-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
  <div class="text-center max-w-3xl mx-auto">
    <h2 id="contact-heading" class="text-headline-large md:text-display-small text-ink-primary">
      {t['calltoaction.heading']}
    </h2>
    <a
      href={EXTERNAL.email}
      class="inline-flex items-center justify-center gap-2 bg-brand-primary text-brand-onPrimary px-8 py-4 rounded-full text-label-large font-medium shadow-elevation-0 hover:shadow-elevation-1 active:shadow-elevation-0 transition-all duration-medium2 ease-standard mt-8"
    >
      {t['calltoaction.button']}
    </a>
  </div>
  </div>
</section>
