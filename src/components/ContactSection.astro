---
import { getRoutes } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();
---

<section id="contact" class="cf-section cf-section--navy" aria-labelledby="contact-heading">
  <div class="cf-container">
    <div class="contact-inner">
      <h2 id="contact-heading" class="cf-h2" style="color: rgb(var(--on-brand-primary));">{t['calltoaction.heading']}</h2>
      <p class="cf-lead" style="margin-top: 16px; max-width: 640px; color: rgb(var(--on-brand-primary) / 0.85);">{t['calltoaction.subtitle']}</p>
      <a href={routes.contact} class="contact-cta">{t['hero.cta']}</a>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    max-width: 920px;
  }
  .contact-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
    padding: 14px 28px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 700;
    background: rgb(var(--surface-base));
    color: rgb(var(--brand-primary));
    border: 1.5px solid rgb(var(--surface-base));
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 200ms ease;
  }
  .contact-cta:hover {
    background: rgb(var(--surface-base) / 0.85);
  }
</style>
