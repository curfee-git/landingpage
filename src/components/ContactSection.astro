---
import { getRoutes } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();
---

<section id="contact" class="uc-section uc-section--navy" aria-labelledby="contact-heading">
  <div class="uc-container">
    <div class="contact-inner">
      <h2 id="contact-heading" class="uc-h2" style="color: rgb(var(--on-brand-primary));">{t['calltoaction.heading']}</h2>
      <p class="uc-lead" style="margin-top: 16px; max-width: 640px; color: rgb(var(--on-brand-primary) / 0.85);">{t['calltoaction.subtitle']}</p>
      <a href={routes.contact} class="contact-cta">{t['hero.cta']}</a>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    max-width: 920px;
  }
  .contact-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
    padding: 14px 28px;
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    background: rgb(var(--on-brand-primary));
    color: rgb(var(--brand-primary));
    border-radius: 8px;
    text-decoration: none;
    transition: filter 140ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .contact-cta:hover {
    filter: brightness(0.92);
  }
</style>
