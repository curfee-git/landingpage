---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
---

<section
  id="why-curfee"
  class="py-20 sm:py-26 xl:py-36 bg-surface-soft"
  aria-labelledby="whycurfee-heading"
>
  <div class="w-full max-w-300 mx-auto px-gutter xl:px-0">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-2">
        <p class="font-sans text-sm font-extrabold tracking-wider uppercase text-brand-primary m-0 mb-4">
          {t['whycurfee.eyebrow']}
        </p>
        <h2
          id="whycurfee-heading"
          data-speakable
          class="font-sans text-3xl md:text-4xl font-extrabold leading-none tracking-tight text-balance break-words hyphens-auto m-0"
        >
          {t['whycurfee.heading.1']}<br />{t['whycurfee.heading.2']}<br class="hidden lg:inline" />{' '}{t['whycurfee.heading.3']}
        </h2>
      </div>
      <div class="lg:col-span-3">
        <p data-speakable class="font-sans text-lg leading-relaxed text-ink-primary/72 m-0">
          {t['whycurfee.body.1']}
        </p>
        <br />
        <p data-speakable class="font-sans text-lg leading-relaxed text-ink-primary/72 m-0">
          {t['whycurfee.body.2']}
        </p>
        <br />
        <p data-speakable class="font-sans text-lg leading-relaxed text-ink-primary/72 m-0">
          {t['whycurfee.body.3']}
        </p>
        <br />
        <p data-speakable class="font-sans text-lg leading-relaxed text-ink-primary/72 m-0">
          {t['whycurfee.body.4']}
        </p>
      </div>
    </div>
  </div>
</section>
