---
import { Image } from 'astro:assets';
import type { Translations } from '@/i18n/translations';
import { getRoutes } from '@/configurations/routes';
import profileImage from '@/assets/images/profile.png';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();
---

<section class="uc-section" aria-labelledby="hero-heading" style="padding-top: 120px; padding-bottom: 120px;">
  <div class="uc-container">
    <div class="hero-grid">

      <div class="hero-inner">
        <p class="uc-eyebrow hero-eyebrow">{t['hero.eyebrow']}</p>

        <h1 id="hero-heading" data-speakable class="uc-h1">
          {t['hero.heading']}{' '}
          <span class="hero-heading-accent">{t['hero.heading.accent']}</span>
        </h1>

        <p data-speakable class="uc-lead" style="margin-top: 28px; max-width: 640px;">
          {t['hero.subtitle']}
        </p>

        <div class="hero-ctas">
          <a href={routes.contact} class="uc-btn uc-btn--primary">
            {t['hero.cta']}
          </a>
          <a href="#services" class="uc-btn uc-btn--secondary">
            {t['hero.cta.secondary']}
          </a>
        </div>
      </div>

      <div class="hero-portrait">
        <Image
          src={profileImage}
          alt={t['about.portrait.alt']}
          class="hero-portrait-img"
          loading="eager"
          decoding="async"
          format="png"
          width={360}
          height={540}
          widths={[240, 360, 480, 720]}
          sizes="(max-width: 900px) 0px, (max-width: 1200px) 320px, 400px"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: 64px;
    align-items: center;
  }
  .hero-inner {
    max-width: 920px;
  }
  .hero-eyebrow {
    margin-bottom: 20px;
  }
  .hero-heading-accent {
    display: block;
    color: rgb(var(--brand-primary));
  }
  .hero-portrait {
    justify-self: end;
    align-self: center;
  }
  .hero-portrait-img {
    display: block;
    width: clamp(240px, 24vw, 400px);
    height: auto;
    border-radius: 12px;
    border: 1px solid rgb(var(--ink-primary) / 0.08);
  }
  .hero-ctas {
    margin-top: 40px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-portrait {
      display: none;
    }
  }
  @media (max-width: 640px) {
    section.uc-section {
      padding-top: 80px !important;
      padding-bottom: 80px !important;
    }
  }
</style>
