---
import { Image } from 'astro:assets';
import type { Translations } from '@/i18n/translations';
import { getRoutes } from '@/configurations/routes';
import profileImage from '@/assets/images/profile.png';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();
---

<section
  class="py-20 sm:py-[104px] xl:py-[144px] lg:min-h-[calc(50svh-36px)] lg:flex lg:items-center"
  aria-labelledby="hero-heading"
>
  <div class="w-full max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] gap-10 lg:gap-16 items-center">

      <div class="max-w-[920px]">
        <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0 mb-5">
          {t['hero.eyebrow']}
        </p>

        <h1
          id="hero-heading"
          data-speakable
          class="font-sans text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.02em] text-balance break-words m-0"
          style="hyphens: manual;"
        >
          {t['hero.heading']}{' '}
          <span class="block">{t['hero.heading.subject']}</span>
          <span class="block text-brand-primary">{t['hero.heading.accent']}</span>
        </h1>

        <p
          data-speakable
          class="text-body-x-large text-ink-muted max-w-[640px] font-medium mt-7"
        >
          {t['hero.subtitle']}
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href={routes.contact}
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 font-sans text-[0.9375rem] font-bold rounded-md no-underline whitespace-nowrap border-[1.5px] cursor-pointer transition-colors duration-200 bg-brand-primary text-brand-onPrimary border-brand-primary hover:bg-[#002952] hover:border-[#002952]"
          >
            {t['hero.cta']}
          </a>
          <a
            href="#services"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 font-sans text-[0.9375rem] font-bold rounded-md no-underline whitespace-nowrap border-[1.5px] cursor-pointer transition-colors duration-200 bg-transparent text-brand-primary border-brand-primary hover:bg-brand-primary/[0.33]"
          >
            {t['hero.cta.secondary']}
          </a>
        </div>
      </div>

      <div class="hidden lg:flex justify-end self-center">
        <Image
          src={profileImage}
          alt={t['about.portrait.alt']}
          class="block w-[clamp(320px,34vw,560px)] h-auto rounded-lg border border-ink-primary/[0.08]"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          width={360}
          height={540}
          widths={[240, 360, 480, 720]}
          sizes="(max-width: 900px) 0px, (max-width: 1200px) 320px, 400px"
        />
      </div>

    </div>
  </div>
</section>
