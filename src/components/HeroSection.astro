---
import { Image } from 'astro:assets';
import type { Translations } from '@/i18n/translations';
import { getRoutes } from '@/configurations/routes';
import profileImage from '@/assets/images/profile.png';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();
---

<section class="cf-section hero-fold" aria-labelledby="hero-heading">
  <div class="cf-container hero-fold-container">
    <div class="hero-grid">

      <div class="hero-inner">
        <p class="cf-eyebrow hero-eyebrow">{t['hero.eyebrow']}</p>

        <h1 id="hero-heading" data-speakable class="cf-h1">
          {t['hero.heading']}{' '}
          <span class="hero-heading-accent">{t['hero.heading.accent']}</span>
        </h1>

        <p data-speakable class="cf-lead" style="margin-top: 28px; max-width: 640px;">
          {t['hero.subtitle']}
        </p>

        <div class="hero-ctas">
          <a href={routes.contact} class="cf-btn cf-btn--primary">
            {t['hero.cta']}
          </a>
          <a href="#services" class="cf-btn cf-btn--secondary">
            {t['hero.cta.secondary']}
          </a>
        </div>
      </div>

      <div class="hero-portrait">
        <Image
          src={profileImage}
          alt={t['about.portrait.alt']}
          class="hero-portrait-img"
          loading="eager"
          decoding="async"
          format="png"
          width={360}
          height={540}
          widths={[240, 360, 480, 720]}
          sizes="(max-width: 900px) 0px, (max-width: 1200px) 320px, 400px"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .hero-fold-container {
    width: 100%;
  }
  @media (min-width: 1024px) {
    .hero-fold {
      min-height: calc(50svh - 36px);
      display: flex;
      align-items: center;
    }
    .hero-fold-container {
      padding-inline: 0;
    }
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  .hero-inner {
    max-width: 920px;
  }
  .hero-eyebrow {
    margin-bottom: 20px;
  }
  .hero-heading-accent {
    display: block;
    color: rgb(var(--brand-primary));
  }
  .hero-portrait {
    display: none;
    justify-self: end;
    align-self: center;
  }
  .hero-portrait-img {
    display: block;
    width: clamp(280px, 28vw, 480px);
    height: auto;
    border-radius: 12px;
    border: 1px solid rgb(var(--ink-primary) / 0.08);
  }
  .hero-ctas {
    margin-top: 40px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  @media (min-width: 901px) {
    .hero-grid {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
      gap: 64px;
    }
    .hero-portrait {
      display: block;
    }
  }
</style>
