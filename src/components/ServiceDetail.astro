---
import Icon from '@/components/shared/Icon.astro';
import { EXTERNAL } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';

interface TimelineStep {
  phase: string;
  title: string;
  outcome: string;
  items: string[];
}

interface Props {
  serviceKey: 'diagnosis' | 'guidance' | 'advisory';
  icon: string;
  title: string;
  subtitle: string;
  duration: string;
  problem: string;
  forwhom: string[];
  timeline: TimelineStep[];
  delivers: string[];
  excludes: string[];
  objectionQ: string;
  objectionA: string;
  cta: string;
  translations: Translations;
  accent: 'primary' | 'secondary' | 'tertiary';
}

const { serviceKey, icon, title, subtitle, duration, problem, forwhom, timeline, delivers, excludes, objectionQ, objectionA, cta, translations: t, accent } = Astro.props;
---

<article class={`service-detail service-detail--${accent}`}>

  <!-- Hero / Page header -->
  <section class="uc-section service-hero">
    <div class="uc-container">
      <a href="/#services" class="service-back">
        <Icon name="arrow_back" class="w-4 h-4" />
        Back to services
      </a>
      <div class="service-hero-grid">
        <div class="service-hero-main">
          <div class="service-hero-icon">
            <Icon name={icon} class="w-7 h-7" />
          </div>
          <p class="uc-eyebrow service-hero-eyebrow">{duration}</p>
          <h1 class="uc-h1 service-hero-title">{title}</h1>
          <p class="service-hero-subtitle">{subtitle}</p>
        </div>
        <aside class="service-hero-aside">
          <p class="uc-body service-hero-problem">{problem}</p>
          <a href={EXTERNAL.mailto} class="service-hero-cta">
            {cta}
            <Icon name="arrow_outward" class="w-4 h-4" />
          </a>
        </aside>
      </div>
    </div>
  </section>

  <!-- For whom -->
  <section class="uc-section uc-section--soft">
    <div class="uc-container">
      <div class="uc-grid-2-3">
        <div>
          <p class="uc-eyebrow">{t['services.label.forwhom']}</p>
          <h2 class="uc-h2" style="margin-top: 16px;">Sound familiar?</h2>
        </div>
        <ul class="service-forwhom">
          {forwhom.map((item) => (
            <li>
              <Icon name="arrow_right_alt" class="service-forwhom-icon" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Process timeline -->
  <section class="uc-section">
    <div class="uc-container">
      <div class="service-process-head">
        <p class="uc-eyebrow">{t['services.label.process']}</p>
        <h2 class="uc-h2" style="margin-top: 16px;">How it unfolds</h2>
      </div>
      <ol class="service-timeline">
        {timeline.map((step, idx) => (
          <li class="service-step">
            <div class="service-step-num">
              <span>{idx + 1}</span>
            </div>
            <div class="service-step-body">
              <p class="uc-eyebrow service-step-phase">{step.phase}</p>
              <h3 class="uc-h3 service-step-title">{step.title}</h3>
              <p class="service-step-outcome">{step.outcome}</p>
              <ul class="service-step-items">
                {step.items.map((item) => (
                  <li>
                    <Icon name="navigate_next" class="service-step-item-icon" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Delivers + Excludes -->
  <section class="uc-section uc-section--soft">
    <div class="uc-container">
      <div class="uc-grid-2 service-bento">
        <div class="service-delivers uc-card">
          <p class="uc-eyebrow service-card-label">{t['services.label.delivers']}</p>
          <ul>
            {delivers.map((item) => (
              <li>
                <Icon name="check_circle" class="service-delivers-icon" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="service-excludes uc-card">
          <p class="uc-eyebrow service-card-label">{t['services.label.excludes']}</p>
          <ul>
            {excludes.map((item) => (
              <li>
                <Icon name="close" class="service-excludes-icon" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Objection -->
  <section class="uc-section">
    <div class="uc-container">
      <div class="service-objection">
        <p class="uc-eyebrow">Common question</p>
        <h2 class="uc-h2" style="margin-top: 16px;">{objectionQ}</h2>
        <p class="uc-lead" style="margin-top: 24px; max-width: 720px;">{objectionA}</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="uc-section uc-section--navy">
    <div class="uc-container">
      <div style="max-width: 760px;">
        <h2 class="uc-h2" style="color: rgb(var(--on-brand-primary));">{t['calltoaction.heading']}</h2>
        <p class="uc-lead" style="margin-top: 16px; max-width: 640px; color: rgb(var(--on-brand-primary) / 0.85);">{t['calltoaction.subtitle']}</p>
        <a href={EXTERNAL.mailto} class="service-final-cta">{cta}</a>
      </div>
    </div>
  </section>

</article>

<style>
  /* Accent colors per service */
  .service-detail--primary { --service-accent: var(--brand-primary); }
  .service-detail--secondary { --service-accent: var(--brand-secondary); }
  .service-detail--tertiary { --service-accent: var(--brand-tertiary); }

  /* Hero */
  .service-hero {
    padding-top: 64px;
  }
  .service-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgb(var(--ink-muted));
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 140ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .service-back:hover {
    color: rgb(var(--service-accent));
  }
  .service-hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .service-hero-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: rgb(var(--service-accent) / 0.1);
    color: rgb(var(--service-accent));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }
  .service-hero-eyebrow {
    margin-bottom: 12px;
  }
  .service-hero-title {
    margin: 0;
  }
  .service-hero-subtitle {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(var(--service-accent));
    margin: 16px 0 0 0;
    line-height: 1.3;
  }
  .service-hero-aside {
    padding: 32px;
    background: rgb(var(--surface-container-low));
    border-radius: 12px;
    border: 1px solid rgb(var(--stroke-subtle));
    position: sticky;
    top: 96px;
  }
  .service-hero-problem {
    margin: 0;
    color: rgb(var(--ink-primary));
    line-height: 1.65;
  }
  .service-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 24px;
    padding: 12px 20px;
    background: rgb(var(--service-accent));
    color: rgb(var(--surface-base));
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    border-radius: 8px;
    text-decoration: none;
    transition: filter 140ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .service-hero-cta:hover {
    filter: brightness(1.1);
  }

  /* For whom */
  .service-forwhom {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .service-forwhom li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: rgb(var(--ink-primary));
  }
  :global(.service-forwhom-icon) {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: rgb(var(--service-accent));
    margin-top: 4px;
  }

  /* Process timeline */
  .service-process-head {
    max-width: 640px;
    margin-bottom: 56px;
  }
  .service-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .service-step {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-top: 1px solid rgb(var(--stroke-subtle));
  }
  .service-step:last-child {
    border-bottom: 1px solid rgb(var(--stroke-subtle));
  }
  .service-step-num {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgb(var(--service-accent) / 0.1);
    color: rgb(var(--service-accent));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Inter Tight", sans-serif;
    font-weight: 700;
    font-size: 1.125rem;
  }
  .service-step-phase {
    margin-bottom: 8px;
  }
  .service-step-title {
    margin: 0 0 4px 0;
    color: rgb(var(--ink-primary));
  }
  .service-step-outcome {
    font-size: 0.9375rem;
    font-style: italic;
    color: rgb(var(--ink-muted));
    margin: 0 0 16px 0;
  }
  .service-step-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .service-step-items li {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    font-size: 0.9375rem;
    color: rgb(var(--ink-muted));
  }
  :global(.service-step-item-icon) {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 4px;
    color: rgb(var(--service-accent) / 0.5);
  }

  /* Delivers + Excludes */
  .service-bento .service-delivers,
  .service-bento .service-excludes {
    background: rgb(var(--surface-base));
  }
  .service-bento ul {
    list-style: none;
    padding: 0;
    margin: 16px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .service-bento li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgb(var(--ink-primary));
  }
  :global(.service-delivers-icon) {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: rgb(var(--service-accent));
    margin-top: 3px;
  }
  :global(.service-excludes-icon) {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: rgb(var(--ink-muted) / 0.4);
    margin-top: 3px;
  }
  .service-card-label {
    margin: 0;
  }

  /* Objection */
  .service-objection {
    max-width: 920px;
  }

  /* Final CTA */
  .service-final-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    padding: 14px 28px;
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    background: rgb(var(--on-brand-primary));
    color: rgb(var(--brand-primary));
    border-radius: 8px;
    text-decoration: none;
    transition: filter 140ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .service-final-cta:hover {
    filter: brightness(0.92);
  }

  @media (max-width: 900px) {
    .service-hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .service-hero-aside {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .service-step {
      grid-template-columns: 48px 1fr;
      gap: 16px;
    }
    .service-step-num {
      width: 40px;
      height: 40px;
    }
  }
</style>
