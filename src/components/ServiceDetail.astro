---
import Icon from '@/components/shared/Icon.astro';
import { getRoutes } from '@/configurations/routes';
import type { ServiceKey } from '@/configurations/services';
import type { Translations } from '@/i18n/translations';

const routes = getRoutes();

interface TimelineStep {
  phase: string;
  title: string;
  outcome: string;
  items: string[];
}

interface Props {
  serviceKey: ServiceKey;
  title: string;
  subtitle: string;
  problem: string;
  timeline: TimelineStep[];
  delivers: string[];
  excludes: string[];
  cta: string;
  translations: Translations;
  accent: 'primary' | 'secondary' | 'tertiary';
}

const { serviceKey, title, subtitle, problem, timeline, delivers, excludes, cta, translations: t } = Astro.props;

const pad2 = (n: number) => String(n).padStart(2, '0');

const approachByService = {
  diagnosis: [
    { title: t['approach.diagnosis.1.title'], body: t['approach.diagnosis.1.body'] },
    { title: t['approach.diagnosis.2.title'], body: t['approach.diagnosis.2.body'] },
    { title: t['approach.diagnosis.3.title'], body: t['approach.diagnosis.3.body'] },
  ],
  guidance: [
    { title: t['approach.guidance.1.title'], body: t['approach.guidance.1.body'] },
    { title: t['approach.guidance.2.title'], body: t['approach.guidance.2.body'] },
    { title: t['approach.guidance.3.title'], body: t['approach.guidance.3.body'] },
  ],
  advisory: [
    { title: t['approach.advisory.1.title'], body: t['approach.advisory.1.body'] },
    { title: t['approach.advisory.2.title'], body: t['approach.advisory.2.body'] },
    { title: t['approach.advisory.3.title'], body: t['approach.advisory.3.body'] },
  ],
} as const;

const fieldsByService = {
  diagnosis: [
    { category: t['fields.diagnosis.1.category'], title: t['fields.diagnosis.1.title'], subtitle: t['fields.diagnosis.1.subtitle'], body: t['fields.diagnosis.1.body'] },
    { category: t['fields.diagnosis.2.category'], title: t['fields.diagnosis.2.title'], subtitle: t['fields.diagnosis.2.subtitle'], body: t['fields.diagnosis.2.body'] },
    { category: t['fields.diagnosis.3.category'], title: t['fields.diagnosis.3.title'], subtitle: t['fields.diagnosis.3.subtitle'], body: t['fields.diagnosis.3.body'] },
    { category: t['fields.diagnosis.4.category'], title: t['fields.diagnosis.4.title'], subtitle: t['fields.diagnosis.4.subtitle'], body: t['fields.diagnosis.4.body'] },
  ],
  guidance: [
    { category: t['fields.guidance.1.category'], title: t['fields.guidance.1.title'], subtitle: t['fields.guidance.1.subtitle'], body: t['fields.guidance.1.body'] },
    { category: t['fields.guidance.2.category'], title: t['fields.guidance.2.title'], subtitle: t['fields.guidance.2.subtitle'], body: t['fields.guidance.2.body'] },
    { category: t['fields.guidance.3.category'], title: t['fields.guidance.3.title'], subtitle: t['fields.guidance.3.subtitle'], body: t['fields.guidance.3.body'] },
    { category: t['fields.guidance.4.category'], title: t['fields.guidance.4.title'], subtitle: t['fields.guidance.4.subtitle'], body: t['fields.guidance.4.body'] },
  ],
  advisory: [
    { category: t['fields.advisory.1.category'], title: t['fields.advisory.1.title'], subtitle: t['fields.advisory.1.subtitle'], body: t['fields.advisory.1.body'] },
    { category: t['fields.advisory.2.category'], title: t['fields.advisory.2.title'], subtitle: t['fields.advisory.2.subtitle'], body: t['fields.advisory.2.body'] },
    { category: t['fields.advisory.3.category'], title: t['fields.advisory.3.title'], subtitle: t['fields.advisory.3.subtitle'], body: t['fields.advisory.3.body'] },
    { category: t['fields.advisory.4.category'], title: t['fields.advisory.4.title'], subtitle: t['fields.advisory.4.subtitle'], body: t['fields.advisory.4.body'] },
  ],
} as const;

const approachItems = approachByService[serviceKey];
const fieldItems = fieldsByService[serviceKey];

const allServices = {
  diagnosis: { href: routes.service.diagnosis, title: t['services.diagnosis.title'], subtitle: t['services.diagnosis.subtitle'] },
  guidance: { href: routes.service.guidance, title: t['services.guidance.title'], subtitle: t['services.guidance.subtitle'] },
  advisory: { href: routes.service.advisory, title: t['services.advisory.title'], subtitle: t['services.advisory.subtitle'] },
} as const;

const relatedByService = {
  diagnosis: [allServices.guidance, allServices.advisory],
  guidance: [allServices.diagnosis, allServices.advisory],
  advisory: [allServices.diagnosis, allServices.guidance],
} as const;

const relatedServices = relatedByService[serviceKey];
---

<article>


  <section class="py-20 sm:py-26 xl:py-36 bg-surface-soft">
    <div class="max-w-300 mx-auto px-gutter xl:px-0">
      <div>
        <h1 class="font-sans text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-none tracking-tight text-balance break-words hyphens-auto m-0">
          {title}
        </h1>
        <p class="font-sans text-2xl font-bold text-brand-primary leading-tight mt-6 m-0">
          {subtitle}
        </p>
        <p class="text-body-x-large font-medium text-ink-muted m-0 mt-6 max-w-prose">
          {problem}
        </p>
      </div>
    </div>
  </section>


  <section class="py-20 sm:py-26 xl:py-36">
    <div class="max-w-300 mx-auto px-gutter xl:px-0">
      <header class="max-w-180 mb-12">
        <p class="font-sans text-sm font-extrabold tracking-wider uppercase text-brand-primary m-0">
          {t['approach.eyebrow']}
        </p>
        <h2 class="font-sans text-3xl md:text-4xl font-extrabold leading-none tracking-tight text-balance break-words hyphens-auto m-0 mt-4">
          {t[`approach.${serviceKey}.heading`]}
        </h2>
      </header>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {approachItems.map((item, idx) => (
          <article class="approach-card flex flex-col gap-4 p-7 bg-surface-base border border-brand-primary rounded-md">
            <div class="font-sans text-3xl font-extrabold tracking-tight text-brand-primary leading-none">
              {pad2(idx + 1)}
            </div>
            <h3 class="text-body-x-large font-bold tracking-normal m-0 text-ink-primary">
              {item.title}
            </h3>
            <p class="font-sans text-base leading-normal text-ink-primary/85 m-0">
              {item.body}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>


  <section class="py-20 sm:py-26 xl:py-36 bg-surface-soft">
    <div class="max-w-300 mx-auto px-gutter xl:px-0">
      <header class="max-w-180 mb-12">
        <p class="font-sans text-sm font-extrabold tracking-wider uppercase text-brand-primary m-0">
          {t['fields.eyebrow']}
        </p>
        <h2 class="font-sans text-3xl md:text-4xl font-extrabold leading-none tracking-tight text-balance break-words hyphens-auto m-0 mt-4">
          {t[`fields.${serviceKey}.heading`]}
        </h2>
      </header>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
        {fieldItems.map((item) => (
          <article class="flex flex-col p-8 bg-surface-base border border-ink-primary/10 rounded-md transition-colors duration-200 hover:border-brand-primary">
            <span class="inline-block self-start justify-self-start font-sans text-xs font-extrabold tracking-widest uppercase text-brand-primary bg-surface-soft py-1.5 px-3 rounded-xs mb-5">
              {item.category}
            </span>
            <h3 class="font-sans text-xl font-extrabold tracking-normal text-ink-primary m-0">
              {item.title}
            </h3>
            {item.subtitle && (
              <p class="font-sans text-base font-bold text-brand-primary leading-snug mt-3 m-0">
                {item.subtitle}
              </p>
            )}
            <p class="font-sans text-base leading-relaxed text-ink-muted mt-5 m-0">
              {item.body}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>


  <section class="py-20 sm:py-26 xl:py-36 bg-brand-primary text-brand-primary-foreground">
    <div class="max-w-300 mx-auto px-gutter xl:px-0">
      <div class="max-w-160 mb-14">
        <p class="font-sans text-sm font-extrabold tracking-wider uppercase text-surface-base/70 m-0">
          {t['services.label.process']}
        </p>
        <h2 class="font-sans text-3xl md:text-4xl font-extrabold leading-none tracking-tight text-balance break-words hyphens-auto m-0 mt-4 text-brand-primary-foreground">
          {t['service.process.heading']}
        </h2>
      </div>
      <ol class="list-none p-0 m-0 flex flex-col gap-2">
        {timeline.map((step, idx) => (
          <li class="flex items-start gap-4 sm:gap-7 py-7 sm:py-8 border-t border-surface-base/15 last:border-b last:border-surface-base/15">
            <div class="w-14 sm:w-22 shrink-0 font-sans font-extrabold text-3xl sm:text-5xl leading-none tracking-tight text-surface-base/50">
              {pad2(idx + 1)}
            </div>
            <div class="flex-1 min-w-0">
              {step.phase && (
                <p class="font-sans text-sm font-extrabold tracking-wider uppercase text-surface-base/70 m-0 mb-2">
                  {step.phase}
                </p>
              )}
              <h3 class="font-sans text-xl md:text-2xl font-bold leading-tight tracking-normal m-0 mb-1 text-brand-primary-foreground">
                {step.title}
              </h3>
              <p class="font-sans text-base text-surface-base/70 m-0 mb-4">
                {step.outcome}
              </p>
              <ul class="list-none p-0 m-0 flex flex-col gap-1.5">
                {step.items.map((item) => (
                  <li class="flex items-start gap-1.5 font-sans text-base text-surface-base/80">
                    <Icon name="navigate_next" class="shrink-0 w-4 h-4 mt-1 text-surface-base/55" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>


  <section class="py-20 sm:py-26 xl:py-36 bg-surface-soft">
    <div class="max-w-300 mx-auto px-gutter xl:px-0">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8">
        <div class="bg-surface-base border border-ink-primary/10 hover:border-brand-primary rounded-md p-6 sm:p-8 transition-colors duration-200">
          <span class="inline-block font-sans text-xs font-extrabold tracking-widest uppercase text-brand-primary bg-surface-soft py-1.5 px-3 rounded-xs m-0 mb-5">
            {t['services.label.delivers']}
          </span>
          <ul class="list-none p-0 m-0 flex flex-col gap-3">
            {delivers.map((item) => (
              <li class="flex items-start gap-2.5 font-sans text-base leading-normal text-ink-primary">
                <Icon name="check_circle" class="shrink-0 w-4.5 h-4.5 text-brand-primary mt-0.75" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-surface-base border border-ink-primary/10 hover:border-brand-primary rounded-md p-6 sm:p-8 transition-colors duration-200">
          <span class="inline-block font-sans text-xs font-extrabold tracking-widest uppercase text-ink-primary/60 bg-ink-primary/6 py-1.5 px-3 rounded-xs m-0 mb-5">
            {t['services.label.excludes']}
          </span>
          <ul class="list-none p-0 m-0 flex flex-col gap-3">
            {excludes.map((item) => (
              <li class="flex items-start gap-2.5 font-sans text-base leading-normal text-ink-primary">
                <Icon name="close" class="shrink-0 w-4.5 h-4.5 text-ink-primary/40 mt-0.75" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>


  <section class="py-20 sm:py-26 xl:py-36" aria-labelledby="related-heading">
    <div class="max-w-300 mx-auto px-gutter xl:px-0">
      <h2 id="related-heading" class="font-sans text-2xl md:text-3xl font-extrabold leading-tight tracking-tight m-0 mb-8">
        {t['services.related.heading']}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedServices.map((s) => (
          <a href={s.href} class="group block p-6 md:p-8 bg-surface-base border border-stroke-subtle rounded-md no-underline transition-transform duration-200 hover:-translate-y-1">
            <h3 class="font-sans text-xl md:text-2xl font-extrabold m-0 mb-2 text-ink-primary transition-colors group-hover:text-brand-primary">
              {s.title}
            </h3>
            <p class="font-sans text-base text-ink-muted leading-normal m-0 mb-4">
              {s.subtitle}
            </p>
            <span class="inline-flex items-center gap-1.5 font-sans text-sm font-bold text-brand-primary">
              {t['services.card.cta']}
              <Icon name="arrow_outward" class="w-4 h-4" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>


  <section class="py-20 sm:py-26 xl:py-36 bg-brand-primary text-brand-primary-foreground">
    <div class="mx-auto px-gutter xl:px-0 text-center max-w-180">
      <h2 class="font-sans text-3xl md:text-4xl font-extrabold leading-none tracking-tight text-balance break-words hyphens-auto m-0 text-brand-primary-foreground">
        {t['calltoaction.heading']}
      </h2>
      <p class="text-body-x-large text-surface-base/85 max-w-140 font-medium mt-6 mx-auto">
        {t['calltoaction.subtitle']}
      </p>
      <a
        href={routes.contact}
        class="inline-flex items-center gap-2 mt-8 px-7 py-3.5 font-sans text-base font-bold bg-surface-base text-brand-primary border-2 border-surface-base rounded-md no-underline transition-colors duration-200 hover:bg-surface-base/85"
      >
        {cta}
      </a>
    </div>
  </section>

</article>

