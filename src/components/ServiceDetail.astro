---
import Icon from '@/components/shared/Icon.astro';
import { getRoutes } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';

const routes = getRoutes();

interface TimelineStep {
  phase: string;
  title: string;
  outcome: string;
  items: string[];
}

interface Props {
  serviceKey: 'diagnosis' | 'guidance' | 'advisory';
  title: string;
  subtitle: string;
  problem: string;
  timeline: TimelineStep[];
  delivers: string[];
  excludes: string[];
  cta: string;
  translations: Translations;
  accent: 'primary' | 'secondary' | 'tertiary';
}

const { serviceKey, title, subtitle, problem, timeline, delivers, excludes, cta, translations: t } = Astro.props;

const pad2 = (n: number) => String(n).padStart(2, '0');

const approachByService = {
  diagnosis: [
    { title: t['approach.diagnosis.1.title'], body: t['approach.diagnosis.1.body'] },
    { title: t['approach.diagnosis.2.title'], body: t['approach.diagnosis.2.body'] },
    { title: t['approach.diagnosis.3.title'], body: t['approach.diagnosis.3.body'] },
  ],
  guidance: [
    { title: t['approach.guidance.1.title'], body: t['approach.guidance.1.body'] },
    { title: t['approach.guidance.2.title'], body: t['approach.guidance.2.body'] },
    { title: t['approach.guidance.3.title'], body: t['approach.guidance.3.body'] },
  ],
  advisory: [
    { title: t['approach.advisory.1.title'], body: t['approach.advisory.1.body'] },
    { title: t['approach.advisory.2.title'], body: t['approach.advisory.2.body'] },
    { title: t['approach.advisory.3.title'], body: t['approach.advisory.3.body'] },
  ],
} as const;

const fieldsByService = {
  diagnosis: [
    { category: t['fields.diagnosis.1.category'], title: t['fields.diagnosis.1.title'], subtitle: t['fields.diagnosis.1.subtitle'], body: t['fields.diagnosis.1.body'] },
    { category: t['fields.diagnosis.2.category'], title: t['fields.diagnosis.2.title'], subtitle: t['fields.diagnosis.2.subtitle'], body: t['fields.diagnosis.2.body'] },
    { category: t['fields.diagnosis.3.category'], title: t['fields.diagnosis.3.title'], subtitle: t['fields.diagnosis.3.subtitle'], body: t['fields.diagnosis.3.body'] },
    { category: t['fields.diagnosis.4.category'], title: t['fields.diagnosis.4.title'], subtitle: t['fields.diagnosis.4.subtitle'], body: t['fields.diagnosis.4.body'] },
  ],
  guidance: [
    { category: t['fields.guidance.1.category'], title: t['fields.guidance.1.title'], subtitle: t['fields.guidance.1.subtitle'], body: t['fields.guidance.1.body'] },
    { category: t['fields.guidance.2.category'], title: t['fields.guidance.2.title'], subtitle: t['fields.guidance.2.subtitle'], body: t['fields.guidance.2.body'] },
    { category: t['fields.guidance.3.category'], title: t['fields.guidance.3.title'], subtitle: t['fields.guidance.3.subtitle'], body: t['fields.guidance.3.body'] },
    { category: t['fields.guidance.4.category'], title: t['fields.guidance.4.title'], subtitle: t['fields.guidance.4.subtitle'], body: t['fields.guidance.4.body'] },
  ],
  advisory: [
    { category: t['fields.advisory.1.category'], title: t['fields.advisory.1.title'], subtitle: t['fields.advisory.1.subtitle'], body: t['fields.advisory.1.body'] },
    { category: t['fields.advisory.2.category'], title: t['fields.advisory.2.title'], subtitle: t['fields.advisory.2.subtitle'], body: t['fields.advisory.2.body'] },
    { category: t['fields.advisory.3.category'], title: t['fields.advisory.3.title'], subtitle: t['fields.advisory.3.subtitle'], body: t['fields.advisory.3.body'] },
    { category: t['fields.advisory.4.category'], title: t['fields.advisory.4.title'], subtitle: t['fields.advisory.4.subtitle'], body: t['fields.advisory.4.body'] },
  ],
} as const;

const approachItems = approachByService[serviceKey];
const fieldItems = fieldsByService[serviceKey];
---

<article>

  <!-- Hero / Page header -->
  <section class="pt-16 sm:pt-[104px] xl:pt-[144px] pb-20 sm:pb-[104px] xl:pb-[144px] bg-surface-soft">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div>
        <h1 class="font-sans text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.02em] text-balance break-words hyphens-auto m-0">
          {title}
        </h1>
        <p class="font-sans text-[1.5rem] font-bold text-brand-primary leading-[1.3] mt-6 m-0">
          {subtitle}
        </p>
        <p class="text-body-x-large font-medium text-ink-muted m-0 mt-6 max-w-[65ch]">
          {problem}
        </p>
      </div>
    </div>
  </section>

  <!-- The approach -->
  <section class="py-20 sm:py-[104px] xl:py-[144px]">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <header class="max-w-[720px] mb-12">
        <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0">
          {t['approach.eyebrow']}
        </p>
        <h2 class="font-sans text-3xl md:text-4xl font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 mt-4">
          {t[`approach.${serviceKey}.heading`]}
        </h2>
      </header>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:grid-rows-[auto_auto_1fr] lg:gap-y-4 lg:gap-x-6">
        {approachItems.map((item, idx) => (
          <article class="approach-card flex flex-col gap-4 p-7 bg-surface-base border border-brand-primary rounded-md lg:grid lg:grid-rows-subgrid lg:row-span-3">
            <div class="font-sans text-[2rem] font-extrabold tracking-[-0.02em] text-brand-primary leading-none">
              {idx + 1}
            </div>
            <h3 class="text-body-x-large font-bold tracking-[-0.005em] m-0 text-ink-primary">
              {item.title}
            </h3>
            <p class="font-sans text-[1rem] leading-[1.55] text-ink-primary/85 m-0">
              {item.body}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Consulting fields -->
  <section class="py-20 sm:py-[104px] xl:py-[144px] bg-surface-soft">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <header class="max-w-[720px] mb-12">
        <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0">
          {t['fields.eyebrow']}
        </p>
        <h2 class="font-sans text-3xl md:text-4xl font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 mt-4">
          {t[`fields.${serviceKey}.heading`]}
        </h2>
      </header>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:grid-rows-[auto_auto_auto] md:gap-8">
        {fieldItems.map((item) => (
          <article class="flex flex-col md:grid md:grid-rows-subgrid md:row-span-3 p-8 bg-surface-base border border-ink-primary/10 rounded-md transition-colors duration-200 hover:border-brand-primary">
            <span class="inline-block self-start justify-self-start font-sans text-[0.6875rem] font-extrabold tracking-[0.16em] uppercase text-brand-primary bg-surface-soft py-1.5 px-3 rounded-xs mb-5 md:mb-0">
              {item.category}
            </span>
            <h3 class="font-sans text-[1.25rem] font-extrabold tracking-[-0.005em] text-ink-primary m-0">
              {item.title}
            </h3>
            {item.subtitle && (
              <p class="font-sans text-[0.9375rem] font-bold text-brand-primary leading-[1.4] mt-2 m-0">
                {item.subtitle}
              </p>
            )}
            <p class="font-sans text-[0.9375rem] leading-[1.6] text-ink-muted mt-5 md:mt-0 m-0">
              {item.body}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Process timeline -->
  <section class="py-20 sm:py-[104px] xl:py-[144px] bg-brand-primary text-brand-onPrimary">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="max-w-[640px] mb-14">
        <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-surface-base/70 m-0">
          {t['services.label.process']}
        </p>
        <h2 class="font-sans text-3xl md:text-4xl font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 mt-4 text-brand-onPrimary">
          {t['service.process.heading']}
        </h2>
      </div>
      <ol class="list-none p-0 m-0 flex flex-col gap-2">
        {timeline.map((step, idx) => (
          <li class="grid grid-cols-[56px_1fr] sm:grid-cols-[88px_1fr] gap-4 sm:gap-7 py-7 sm:py-8 border-t border-surface-base/[0.15] last:border-b last:border-surface-base/[0.15]">
            <div class="font-sans font-extrabold text-[2rem] sm:text-[2.75rem] leading-none tracking-[-0.02em] text-surface-base/50">
              {pad2(idx + 1)}
            </div>
            <div>
              {step.phase && (
                <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-surface-base/70 m-0 mb-2">
                  {step.phase}
                </p>
              )}
              <h3 class="font-sans text-xl md:text-2xl font-bold leading-tight tracking-[-0.005em] m-0 mb-1 text-brand-onPrimary">
                {step.title}
              </h3>
              <p class="font-sans text-[0.9375rem] text-surface-base/70 m-0 mb-4">
                {step.outcome}
              </p>
              <ul class="list-none p-0 m-0 flex flex-col gap-1.5">
                {step.items.map((item) => (
                  <li class="flex items-start gap-1.5 font-sans text-[0.9375rem] text-surface-base/80">
                    <Icon name="navigate_next" class="shrink-0 w-4 h-4 mt-1 text-surface-base/55" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Delivers + Excludes -->
  <section class="py-20 sm:py-[104px] xl:py-[144px] bg-surface-soft">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8">
        <div class="bento-card bg-surface-base border border-ink-primary/10 rounded-md p-6 sm:p-8 transition-colors duration-200">
          <span class="inline-block font-sans text-[0.6875rem] font-extrabold tracking-[0.16em] uppercase text-brand-primary bg-surface-soft py-1.5 px-3 rounded-xs m-0 mb-5">
            {t['services.label.delivers']}
          </span>
          <ul class="list-none p-0 m-0 flex flex-col gap-3">
            {delivers.map((item) => (
              <li class="flex items-start gap-2.5 font-sans text-[0.9375rem] leading-[1.55] text-ink-primary">
                <Icon name="check_circle" class="shrink-0 w-[18px] h-[18px] text-brand-primary mt-[3px]" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bento-card bg-surface-base border border-ink-primary/10 rounded-md p-6 sm:p-8 transition-colors duration-200">
          <span class="inline-block font-sans text-[0.6875rem] font-extrabold tracking-[0.16em] uppercase text-ink-primary/60 bg-ink-primary/[0.06] py-1.5 px-3 rounded-xs m-0 mb-5">
            {t['services.label.excludes']}
          </span>
          <ul class="list-none p-0 m-0 flex flex-col gap-3">
            {excludes.map((item) => (
              <li class="flex items-start gap-2.5 font-sans text-[0.9375rem] leading-[1.55] text-ink-primary">
                <Icon name="close" class="shrink-0 w-[18px] h-[18px] text-ink-primary/40 mt-[3px]" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-[104px] xl:py-[144px] bg-brand-primary text-brand-onPrimary">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0 text-center max-w-[720px]">
      <h2 class="font-sans text-3xl md:text-4xl font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 text-brand-onPrimary">
        {t['calltoaction.heading']}
      </h2>
      <p class="text-body-x-large text-surface-base/85 max-w-[560px] font-medium mt-6 mx-auto">
        {t['calltoaction.subtitle']}
      </p>
      <a
        href={routes.contact}
        class="inline-flex items-center gap-2 mt-8 px-7 py-3.5 font-sans text-[0.9375rem] font-bold bg-surface-base text-brand-primary border-[1.5px] border-surface-base rounded-md no-underline transition-colors duration-200 hover:bg-surface-base/85"
      >
        {cta}
      </a>
    </div>
  </section>

</article>

<style>
  .bento-card:hover {
    border-color: rgb(var(--brand-primary));
  }
</style>
