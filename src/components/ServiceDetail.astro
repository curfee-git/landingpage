---
import Icon from '@/components/shared/Icon.astro';
import { getRoutes } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';

const routes = getRoutes();

interface TimelineStep {
  phase: string;
  title: string;
  outcome: string;
  items: string[];
}

interface Props {
  serviceKey: 'diagnosis' | 'guidance' | 'advisory';
  title: string;
  subtitle: string;
  duration: string;
  problem: string;
  forwhom: string[];
  timeline: TimelineStep[];
  delivers: string[];
  excludes: string[];
  objectionQ: string;
  objectionA: string;
  cta: string;
  translations: Translations;
  accent: 'primary' | 'secondary' | 'tertiary';
}

const { title, subtitle, duration, problem, forwhom, timeline, delivers, excludes, objectionQ, objectionA, cta, translations: t, accent } = Astro.props;
---

<article class={`service-detail service-detail--${accent}`}>

  <!-- Hero / Page header -->
  <section class="cf-section service-hero">
    <div class="cf-container">
      <div class="service-hero-grid">
        <div class="service-hero-main">
          <p class="cf-eyebrow service-hero-eyebrow">{duration}</p>
          <h1 class="cf-h1 service-hero-title">{title}</h1>
          <p class="service-hero-subtitle">{subtitle}</p>
        </div>
        <aside class="service-hero-aside">
          <p class="cf-body service-hero-problem">{problem}</p>
          <a href={routes.contact} class="service-hero-cta">
            {cta}
            <Icon name="arrow_outward" class="w-4 h-4" />
          </a>
        </aside>
      </div>
    </div>
  </section>

  <!-- For whom -->
  <section class="cf-section cf-section--soft">
    <div class="cf-container">
      <div class="cf-grid-2-3">
        <div>
          <p class="cf-eyebrow">{t['services.label.forwhom']}</p>
          <h2 class="cf-h2" style="margin-top: 16px;">Klingt das vertraut?</h2>
        </div>
        <ul class="service-forwhom">
          {forwhom.map((item) => (
            <li>
              <Icon name="arrow_right_alt" class="service-forwhom-icon" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Process timeline -->
  <section class="cf-section">
    <div class="cf-container">
      <div class="service-process-head">
        <p class="cf-eyebrow">{t['services.label.process']}</p>
        <h2 class="cf-h2" style="margin-top: 16px;">Wie es abläuft</h2>
      </div>
      <ol class="service-timeline">
        {timeline.map((step, idx) => (
          <li class="service-step">
            <div class="service-step-num">
              <span>{idx + 1}</span>
            </div>
            <div class="service-step-body">
              <p class="cf-eyebrow service-step-phase">{step.phase}</p>
              <h3 class="cf-h3 service-step-title">{step.title}</h3>
              <p class="service-step-outcome">{step.outcome}</p>
              <ul class="service-step-items">
                {step.items.map((item) => (
                  <li>
                    <Icon name="navigate_next" class="service-step-item-icon" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Delivers + Excludes -->
  <section class="cf-section cf-section--soft">
    <div class="cf-container">
      <div class="cf-grid-2 service-bento">
        <div class="service-delivers cf-card">
          <p class="cf-eyebrow service-card-label">{t['services.label.delivers']}</p>
          <ul>
            {delivers.map((item) => (
              <li>
                <Icon name="check_circle" class="service-delivers-icon" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="service-excludes cf-card">
          <p class="cf-eyebrow service-card-label">{t['services.label.excludes']}</p>
          <ul>
            {excludes.map((item) => (
              <li>
                <Icon name="close" class="service-excludes-icon" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Objection -->
  <section class="cf-section">
    <div class="cf-container">
      <div class="service-objection">
        <p class="cf-eyebrow">Häufige Frage</p>
        <h2 class="cf-h2" style="margin-top: 16px;">{objectionQ}</h2>
        <p class="cf-lead" style="margin-top: 24px; max-width: 720px;">{objectionA}</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cf-section cf-section--navy">
    <div class="cf-container">
      <div style="max-width: 760px;">
        <h2 class="cf-h2" style="color: rgb(var(--on-brand-primary));">{t['calltoaction.heading']}</h2>
        <p class="cf-lead" style="margin-top: 16px; max-width: 640px; color: rgb(var(--on-brand-primary) / 0.85);">{t['calltoaction.subtitle']}</p>
        <a href={routes.contact} class="service-final-cta">{cta}</a>
      </div>
    </div>
  </section>

</article>

<style>
  /* All services share the same brand accents – no per-service hue */

  /* Hero */
  .service-hero {
    padding-top: 64px;
  }
  .service-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
  }
  .service-hero-eyebrow {
    margin-bottom: 12px;
  }
  .service-hero-title {
    margin: 0;
  }
  .service-hero-subtitle {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    color: rgb(var(--brand-primary));
    margin: 16px 0 0 0;
    line-height: 1.3;
  }
  .service-hero-aside {
    padding: 32px;
    background: rgb(var(--surface-soft));
    border-radius: 8px;
    border: 1px solid rgb(var(--ink-primary) / 0.1);
    position: static;
  }
  .service-hero-problem {
    margin: 0;
    color: rgb(var(--ink-primary));
    line-height: 1.6;
    max-width: 65ch;
  }
  .service-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 24px;
    padding: 12px 20px;
    background: rgb(var(--brand-primary));
    color: rgb(var(--on-brand-primary));
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 700;
    border: 1.5px solid rgb(var(--brand-primary));
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 200ms ease, border-color 200ms ease;
  }
  .service-hero-cta:hover {
    background: color-mix(in srgb, rgb(var(--brand-primary)) 80%, black);
    border-color: color-mix(in srgb, rgb(var(--brand-primary)) 80%, black);
  }

  /* For whom */
  .service-forwhom {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .service-forwhom li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: rgb(var(--ink-primary));
  }
  :global(.service-forwhom-icon) {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: rgb(var(--brand-primary));
    margin-top: 4px;
  }

  /* Process timeline */
  .service-process-head {
    max-width: 640px;
    margin-bottom: 56px;
  }
  .service-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .service-step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px;
    padding: 28px 0;
    border-top: 1px solid rgb(var(--ink-primary) / 0.1);
  }
  .service-step:last-child {
    border-bottom: 1px solid rgb(var(--ink-primary) / 0.1);
  }
  .service-step-num {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    background: rgb(var(--brand-primary));
    color: rgb(var(--on-brand-primary));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 1.125rem;
  }
  .service-step-phase {
    margin-bottom: 8px;
  }
  .service-step-title {
    margin: 0 0 4px 0;
    color: rgb(var(--ink-primary));
  }
  .service-step-outcome {
    font-size: 0.9375rem;
    color: rgb(var(--ink-primary) / 0.65);
    margin: 0 0 16px 0;
  }
  .service-step-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .service-step-items li {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    font-size: 0.9375rem;
    color: rgb(var(--ink-primary) / 0.75);
  }
  :global(.service-step-item-icon) {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 4px;
    color: rgb(var(--brand-primary));
  }

  /* Delivers + Excludes */
  .service-bento .service-delivers,
  .service-bento .service-excludes {
    background: rgb(var(--surface-base));
  }
  .service-bento ul {
    list-style: none;
    padding: 0;
    margin: 16px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .service-bento li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgb(var(--ink-primary));
  }
  :global(.service-delivers-icon) {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: rgb(var(--brand-primary));
    margin-top: 3px;
  }
  :global(.service-excludes-icon) {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: rgb(var(--ink-primary) / 0.4);
    margin-top: 3px;
  }
  .service-card-label {
    margin: 0;
  }

  /* Objection */
  .service-objection {
    max-width: 920px;
  }

  /* Final CTA */
  .service-final-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    padding: 14px 28px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 700;
    background: rgb(var(--surface-base));
    color: rgb(var(--brand-primary));
    border: 1.5px solid rgb(var(--surface-base));
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 200ms ease;
  }
  .service-final-cta:hover {
    background: rgb(var(--surface-base) / 0.85);
  }

  @media (min-width: 641px) {
    .service-step {
      grid-template-columns: 64px 1fr;
      gap: 24px;
    }
    .service-step-num {
      width: 48px;
      height: 48px;
    }
  }

  @media (min-width: 901px) {
    .service-hero-grid {
      grid-template-columns: 1.4fr 1fr;
      gap: 64px;
    }
    .service-hero-aside {
      position: sticky;
      top: 96px;
    }
  }
</style>
