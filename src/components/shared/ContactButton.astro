---
import { EXTERNAL } from '@/configurations/routes';

interface Props {
  label: string;
  variant?: 'filled' | 'outlined' | 'text';
  class?: string;
}

const { label, variant = 'outlined', class: className = '' } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-md text-label-large font-bold transition-colors duration-short4 ease-standard';

const variantClasses = {
  filled: 'bg-brand-primary text-brand-onPrimary hover:bg-brand-primary/85',
  outlined: 'border-[1.5px] border-brand-primary text-brand-primary hover:bg-brand-primary hover:text-brand-onPrimary',
  text: 'text-brand-primary border-b border-transparent hover:border-brand-primary',
};
---

<a
  href={EXTERNAL.mailto}
  class:list={[baseClasses, variantClasses[variant], className]}
  aria-label={label}
>
  {label}
  <slot />
</a>
