---
import Icon from '@/components/shared/Icon.astro';
---

<button
  type="button"
  class="fixed bottom-20 md:bottom-6 right-6 z-30 w-12 h-12 rounded-full flex items-center justify-center bg-surface-raised border border-stroke-outlineVariant text-brand-primary shadow-elevation-2 hover:shadow-elevation-3 hover:bg-brand-primary/[0.08] active:shadow-elevation-2 active:bg-brand-primary/[0.12] transition-all duration-medium2 ease-standard opacity-0 translate-y-4 pointer-events-none"
  aria-label="Scroll to top"
  data-scroll-top
>
  <Icon name="expand_less" class="w-6 h-6" />
</button>

<script>
  import { initFab } from '@/ui/ScrollToTopButton';
  document.addEventListener('astro:page-load', () => initFab());
</script>
