---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { resolveLocale } from '@/i18n/translations';

const currentLocale = resolveLocale(Astro.currentLocale);
const otherLocale = currentLocale === 'en' ? 'de' : 'en';
const stripped = Astro.url.pathname
  .replace(/^\/(en|de)(\/|$)/, '/')
  .replace(/^\//, '');
const otherHref = getRelativeLocaleUrl(otherLocale, stripped);

const labels = { en: 'English', de: 'Deutsch' } as const;
const currentLabel = labels[currentLocale];
---

<a
  href={otherHref}
  class="lang-toggle"
  data-lang-toggle-link
  data-locale={otherLocale}
  aria-label={`Switch to ${labels[otherLocale]}`}
>
  {currentLabel}
</a>

<script>
  import { initLanguageToggle } from '@/scripts/language-toggle';
  initLanguageToggle();
  document.addEventListener('astro:page-load', () => initLanguageToggle());
</script>

<style>
  .lang-toggle {
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgb(var(--ink-muted));
    text-decoration: none;
    transition: color 140ms cubic-bezier(0.2, 0, 0, 1);
  }
  .lang-toggle:hover,
  .lang-toggle:focus-visible {
    color: rgb(var(--ink-primary));
    outline: none;
  }
</style>
