---
import Icon from '@/components/shared/Icon.astro';
import { getRoutes } from '@/configurations/routes';
import { getTranslations } from '@/i18n/translations';
import logoTextRaw from '@/assets/logos/logo_text.svg?raw';

const t = getTranslations();
const routes = getRoutes();
const menuId = 'mobile-menu';
const navClass = "px-5 py-3 text-label-large font-semibold whitespace-nowrap text-ink-muted hover:text-brand-secondary transition-colors duration-short4 ease-standard";
const menuItemClass = "flex items-center px-4 py-3 text-label-large font-semibold transition-colors duration-short4 ease-standard text-ink-primary hover:text-brand-secondary";
---

<header class="z-20 sticky top-0" role="banner" data-header>
  <div class="mx-auto max-w-7xl flex items-center justify-between gap-3 w-full relative h-[clamp(72px,4.17vw,120px)] px-6 md:px-12 lg:px-20" data-header-shell>
    <a href={routes.home} class="shrink-0 inline-flex items-center gap-2 text-brand-primary" aria-label="Curfee">
      <span class="block h-10 [&>svg]:h-full [&>svg]:max-h-full [&>svg]:w-auto" aria-hidden="true" set:html={logoTextRaw} />
    </a>

    <nav class="hidden lg:flex items-center gap-1" aria-label="Hauptnavigation">
      <a href={routes.home} class={navClass} data-nav-link>{t['nav.home']}</a>

      <div class="services-dropdown" data-services-dropdown>
        <button
          type="button"
          class={`${navClass} services-dropdown-trigger`}
          aria-haspopup="true"
          aria-expanded="false"
          data-services-trigger
        >
          {t['nav.services']}
        </button>
        <div class="services-dropdown-menu" role="menu" data-services-menu>
          <a href={routes.service.diagnosis} class="services-dropdown-item" role="menuitem" data-nav-link>
            <span class="services-dropdown-item-title">{t['services.diagnosis.title']}</span>
            <span class="services-dropdown-item-desc">{t['services.diagnosis.subtitle']}</span>
          </a>
          <a href={routes.service.guidance} class="services-dropdown-item" role="menuitem" data-nav-link>
            <span class="services-dropdown-item-title">{t['services.guidance.title']}</span>
            <span class="services-dropdown-item-desc">{t['services.guidance.subtitle']}</span>
          </a>
          <a href={routes.service.advisory} class="services-dropdown-item" role="menuitem" data-nav-link>
            <span class="services-dropdown-item-title">{t['services.advisory.title']}</span>
            <span class="services-dropdown-item-desc">{t['services.advisory.subtitle']}</span>
          </a>
        </div>
      </div>

      <a href={routes.about} class={navClass} data-nav-link>{t['nav.about']}</a>
      <a href={routes.blog} class={navClass} data-nav-link>{t['nav.blog']}</a>
    </nav>

    <div class="flex items-center gap-1 shrink-0 z-10">
      <a href={routes.contact} class="hidden sm:inline-flex items-center justify-center gap-2 bg-brand-primary text-brand-onPrimary px-6 py-3.5 rounded-md text-sm font-bold tracking-wide leading-none whitespace-nowrap hover:brightness-110 active:scale-[0.98] transition-all duration-short4 ease-standard">
        <span>{t['nav.cta']}</span>
      </a>
      <button type="button" class="lg:hidden inline-flex h-12 w-12 items-center justify-center rounded-full text-ink-primary hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard" aria-label="Navigation umschalten" aria-expanded="false" aria-controls={menuId} data-menu-toggle>
        <span data-menu-icon="closed"><Icon name="menu" class="w-6 h-6" /></span>
        <span data-menu-icon="open" style="display:none"><Icon name="close" class="w-6 h-6" /></span>
      </button>
    </div>
  </div>

  <div id={menuId} inert data-mobile-menu class="lg:hidden absolute -left-px -right-px transition-[max-height,opacity] duration-medium2 ease-standard max-h-0 opacity-0 pointer-events-none overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-12 pb-4 space-y-2">
      <nav class="flex flex-col gap-1" aria-label="Mobile Navigation">
        <a href={routes.home} class={menuItemClass} data-menu-close data-nav-link>{t['nav.home']}</a>
        <p class="px-4 pt-3 pb-1 text-label-medium uppercase tracking-wider text-ink-muted">{t['nav.services']}</p>
        <a href={routes.service.diagnosis} class={`${menuItemClass} pl-7`} data-menu-close data-nav-link>{t['services.diagnosis.title']}</a>
        <a href={routes.service.guidance} class={`${menuItemClass} pl-7`} data-menu-close data-nav-link>{t['services.guidance.title']}</a>
        <a href={routes.service.advisory} class={`${menuItemClass} pl-7`} data-menu-close data-nav-link>{t['services.advisory.title']}</a>
        <a href={routes.about} class={menuItemClass} data-menu-close data-nav-link>{t['nav.about']}</a>
        <a href={routes.blog} class={menuItemClass} data-menu-close data-nav-link>{t['nav.blog']}</a>
      </nav>
      <div class="sm:hidden flex flex-col gap-2 px-4 pt-2">
        <a href={routes.contact} class="inline-flex items-center justify-center gap-2 bg-brand-primary text-brand-onPrimary px-6 py-3.5 rounded-md text-sm font-bold tracking-wide leading-none hover:brightness-110 active:scale-[0.98] transition-all duration-short4 ease-standard" data-menu-close>{t['nav.cta']}</a>
      </div>
    </div>
  </div>
</header>

<style>
  [data-nav-link][data-active] {
    color: rgb(var(--brand-primary));
  }

  /* Services dropdown */
  .services-dropdown {
    position: relative;
  }
  .services-dropdown-trigger {
    display: inline-flex;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .services-dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 280px;
    margin-top: 8px;
    padding: 8px;
    background: rgb(var(--surface-base));
    border: 1px solid rgb(var(--stroke-subtle));
    border-radius: 12px;
    box-shadow: 0 12px 32px rgb(var(--shadow-color) / 0.08), 0 2px 6px rgb(var(--shadow-color) / 0.04);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 160ms cubic-bezier(0.2, 0, 0, 1), transform 160ms cubic-bezier(0.2, 0, 0, 1), visibility 0s linear 160ms;
    z-index: 30;
  }
  .services-dropdown[data-open] .services-dropdown-menu,
  .services-dropdown:hover .services-dropdown-menu,
  .services-dropdown:focus-within .services-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 160ms cubic-bezier(0.2, 0, 0, 1), transform 160ms cubic-bezier(0.2, 0, 0, 1), visibility 0s linear 0s;
  }
  /* Bridge the 8px gap between button and menu so hover doesn't drop */
  .services-dropdown::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 12px;
    pointer-events: auto;
  }
  .services-dropdown-item {
    display: block;
    padding: 12px 14px;
    border-radius: 8px;
    text-decoration: none;
    color: rgb(var(--ink-primary));
    transition: background-color 140ms cubic-bezier(0.2, 0, 0, 1);
  }
  .services-dropdown-item:hover {
    background: rgb(var(--brand-primary) / 0.06);
  }
  .services-dropdown-item-title {
    display: block;
    font-size: 0.9375rem;
    font-weight: 700;
    color: rgb(var(--ink-primary));
  }
  .services-dropdown-item:hover .services-dropdown-item-title {
    color: rgb(var(--brand-primary));
  }
  .services-dropdown-item-desc {
    display: block;
    font-size: 0.8125rem;
    color: rgb(var(--ink-muted));
    margin-top: 2px;
  }
  [data-header] {
    --menu-height: 0px;
  }
  [data-header]::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgb(var(--surface-soft) / 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: -1;
  }
  @media (max-width: 1023px) {
    [data-header]::before {
      height: calc(100% + var(--menu-height));
    }
  }
</style>

<script>
  let cleanupHandlers: Array<() => void> = [];

  function addCleanup(fn: () => void) {
    cleanupHandlers.push(fn);
  }

  function runCleanup() {
    for (const fn of cleanupHandlers) {
      try { fn(); } catch { /* ignore */ }
    }
    cleanupHandlers = [];
  }

  function initHeader() {
    const header = document.querySelector('[data-header]') as HTMLElement | null;
    const toggle = header?.querySelector('[data-menu-toggle]') as HTMLButtonElement | null;
    const menu = header?.querySelector('[data-mobile-menu]') as HTMLDivElement | null;
    const closeTargets = header?.querySelectorAll('[data-menu-close]') ?? [];
    const iconOpen = header?.querySelector('[data-menu-icon="open"]') as HTMLElement | null;
    const iconClosed = header?.querySelector('[data-menu-icon="closed"]') as HTMLElement | null;

    let menuOpen = false;
    const updateMenuHeight = () => {
      if (!menu || !header) return;
      header.style.setProperty('--menu-height', menuOpen ? `${menu.scrollHeight}px` : '0px');
    };

    if (menu) {
      const menuObserver = new ResizeObserver(updateMenuHeight);
      menuObserver.observe(menu);
      addCleanup(() => menuObserver.disconnect());
    }

    const setMenuState = (open: boolean) => {
      if (!menu || !toggle || !header) return;
      menuOpen = open;
      updateMenuHeight();
      menu.style.maxHeight = open ? '30rem' : '0px';
      menu.style.opacity = open ? '1' : '0';
      menu.style.pointerEvents = open ? 'auto' : 'none';
      menu.inert = !open;
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) {
        header.setAttribute('data-menu-open', '');
      } else {
        header.removeAttribute('data-menu-open');
      }
      if (iconOpen && iconClosed) {
        iconOpen.style.display = open ? 'inline-block' : 'none';
        iconClosed.style.display = open ? 'none' : 'inline-block';
      }
    };

    if (toggle) {
      let open = false;
      const onToggle = () => { open = !open; setMenuState(open); };
      toggle.addEventListener('click', onToggle);
      addCleanup(() => toggle.removeEventListener('click', onToggle));

      const closeListeners: Array<[Element, () => void]> = [];
      closeTargets.forEach((el) => {
        const fn = () => { open = false; setMenuState(open); };
        el.addEventListener('click', fn);
        closeListeners.push([el, fn]);
      });
      addCleanup(() => closeListeners.forEach(([el, fn]) => el.removeEventListener('click', fn)));

      const onKeyDown = (event: KeyboardEvent) => {
        if (event.key === 'Escape' && open) { open = false; setMenuState(open); toggle.focus(); }
      };
      document.addEventListener('keydown', onKeyDown);
      addCleanup(() => document.removeEventListener('keydown', onKeyDown));

      const onDocClick = (event: MouseEvent) => {
        if (open && header && !header.contains(event.target as Node)) {
          open = false; setMenuState(open);
        }
      };
      document.addEventListener('click', onDocClick);
      addCleanup(() => document.removeEventListener('click', onDocClick));
    }
  }

  function initActiveSection() {
    const navLinks = document.querySelectorAll('[data-nav-link]') as NodeListOf<HTMLAnchorElement>;
    const sectionIds = ['observations', 'services', 'blog', 'faq', 'contact'];
    const sections = sectionIds
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    // Skip entirely on pages with no tracked sections (blog posts, legal, etc.)
    if (sections.length === 0) return;

    let currentActive = '';

    const setActive = (id: string) => {
      if (id === currentActive) return;
      currentActive = id;
      navLinks.forEach((link) => {
        if (link.hash === `#${id}`) {
          link.setAttribute('data-active', '');
        } else {
          link.removeAttribute('data-active');
        }
      });
      history.replaceState(null, '', `#${id}`);
    };

    const clearActive = () => {
      if (!currentActive) return;
      currentActive = '';
      navLinks.forEach((link) => link.removeAttribute('data-active'));
      history.replaceState(null, '', location.pathname);
    };

    const onScroll = () => {
      const scrollY = window.scrollY;
      const viewportMiddle = scrollY + window.innerHeight * 0.35;

      // In hero zone, no highlight
      const firstSection = sections[0];
      if (firstSection && viewportMiddle < firstSection.offsetTop) {
        clearActive();
        return;
      }

      // Find the section whose top is closest to (but not past) the viewport trigger
      let active = '';
      for (const section of sections) {
        if (section.offsetTop <= viewportMiddle) {
          active = section.id;
        }
      }
      if (active) {
        setActive(active);
      } else {
        clearActive();
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    addCleanup(() => window.removeEventListener('scroll', onScroll));

    // If the page was loaded with a section hash (e.g. browser back to /#blog),
    // pre-populate state from the hash and explicitly scroll to the section.
    // Relying on the browser's native anchor scroll is unreliable after a
    // full-page back-navigation, especially with bfcache or lazy-loaded content
    // above the target section.
    const hashId = location.hash.startsWith('#') ? location.hash.slice(1) : '';
    const hashSection = hashId ? sections.find((s) => s.id === hashId) : undefined;
    if (hashSection) {
      currentActive = hashId;
      navLinks.forEach((link) => {
        if (link.hash === `#${hashId}`) {
          link.setAttribute('data-active', '');
        } else {
          link.removeAttribute('data-active');
        }
      });

      // Wait two frames so any lazy layout above the target settles before
      // measuring offsetTop, then scroll if the browser hasn't already.
      const scrollToSection = () => {
        const target = hashSection.offsetTop;
        if (Math.abs(window.scrollY - target) > 4) {
          window.scrollTo({ top: target, behavior: 'auto' });
        }
      };
      requestAnimationFrame(() => requestAnimationFrame(scrollToSection));
    } else {
      onScroll();
    }
  }

  function initServicesDropdown() {
    const dropdown = document.querySelector('[data-services-dropdown]') as HTMLElement | null;
    if (!dropdown) return;
    const trigger = dropdown.querySelector('[data-services-trigger]') as HTMLButtonElement | null;
    const menu = dropdown.querySelector('[data-services-menu]') as HTMLElement | null;
    if (!trigger || !menu) return;

    let open = false;
    let hoverCloseTimer: number | null = null;

    const setOpen = (next: boolean) => {
      open = next;
      if (open) {
        dropdown.setAttribute('data-open', '');
        trigger.setAttribute('aria-expanded', 'true');
      } else {
        dropdown.removeAttribute('data-open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    };

    const cancelClose = () => {
      if (hoverCloseTimer !== null) {
        window.clearTimeout(hoverCloseTimer);
        hoverCloseTimer = null;
      }
    };

    const scheduleClose = () => {
      cancelClose();
      hoverCloseTimer = window.setTimeout(() => setOpen(false), 120);
    };

    const onTriggerClick = (e: MouseEvent) => {
      e.stopPropagation();
      cancelClose();
      setOpen(!open);
    };
    const onEnter = () => { cancelClose(); setOpen(true); };
    const onLeave = () => { scheduleClose(); };
    const onDocClick = (e: MouseEvent) => {
      if (!dropdown.contains(e.target as Node)) setOpen(false);
    };
    const onKeyDown = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && open) {
        setOpen(false);
        trigger.focus();
      }
    };
    const onItemFocusOut = (e: FocusEvent) => {
      const next = e.relatedTarget as Node | null;
      if (!next || !dropdown.contains(next)) setOpen(false);
    };

    trigger.addEventListener('click', onTriggerClick);
    dropdown.addEventListener('mouseenter', onEnter);
    dropdown.addEventListener('mouseleave', onLeave);
    document.addEventListener('click', onDocClick);
    document.addEventListener('keydown', onKeyDown);
    menu.addEventListener('focusout', onItemFocusOut);

    addCleanup(() => {
      trigger.removeEventListener('click', onTriggerClick);
      dropdown.removeEventListener('mouseenter', onEnter);
      dropdown.removeEventListener('mouseleave', onLeave);
      document.removeEventListener('click', onDocClick);
      document.removeEventListener('keydown', onKeyDown);
      menu.removeEventListener('focusout', onItemFocusOut);
      cancelClose();
    });
  }

  document.addEventListener('astro:before-swap', runCleanup);
  document.addEventListener('astro:page-load', () => {
    runCleanup();
    initHeader();
    initActiveSection();
    initServicesDropdown();
  });
</script>
