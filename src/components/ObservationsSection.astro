---
import Icon from '@/components/shared/Icon.astro';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const cards = [
  { icon: 'rule', title: t['observations.1.title'], text: t['observations.1.reality'] },
  { icon: 'account_tree', title: t['observations.2.title'], text: t['observations.2.reality'] },
  { icon: 'call_split', title: t['observations.3.title'], text: t['observations.3.reality'] },
  { icon: 'code', title: t['observations.7.title'], text: t['observations.7.reality'] },
  { icon: 'psychology', title: t['observations.4.title'], text: t['observations.4.reality'] },
  { icon: 'route', title: t['observations.5.title'], text: t['observations.5.reality'] },
  { icon: 'explore', title: t['observations.6.title'], text: t['observations.6.reality'] },
];

const loop = [...cards, ...cards];
---

<section
  id="observations"
  class="py-20 sm:py-[104px] xl:py-[144px]"
  aria-labelledby="observations-heading"
>
  <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
    <div class="max-w-[920px]">
      <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0 mb-4">
        {t['observations.subtitle.status_quo']}
      </p>
      <h2
        id="observations-heading"
        data-speakable
        class="font-sans text-3xl md:text-4xl font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0"
      >
        {t['observations.heading.status_quo']}
      </h2>
    </div>
  </div>

  <div class="obs-carousel mt-12" role="region" aria-label={t['observations.heading.status_quo']}>
    <ul class="obs-track flex w-max m-0 py-1 list-none" role="list">
      {loop.map((card, i) => (
        <li
          class="flex flex-col flex-[0_0_320px] min-h-[220px] mr-4 p-6 bg-surface-base ring-1 ring-inset ring-ink-primary/[0.18] rounded-md backface-hidden"
          aria-hidden={i >= cards.length ? 'true' : undefined}
        >
          <Icon name={card.icon} class="w-6 h-6 text-brand-primary shrink-0" />
          <h3 class="text-title-medium font-semibold text-ink-primary mt-3 mb-2">{card.title}</h3>
          <p class="text-body-medium text-ink-muted leading-relaxed">{card.text}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .obs-carousel {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
  }

  .obs-track {
    --obs-cards: 7;
    --obs-card-w: 320px;
    --obs-card-gap: 16px;
    animation: obs-scroll 75s linear infinite;
    will-change: transform;
  }

  .obs-track > li {
    transform: translateZ(0);
  }

  .obs-carousel:hover .obs-track,
  .obs-carousel:focus-within .obs-track {
    animation-play-state: paused;
  }

  @keyframes obs-scroll {
    from { transform: translate3d(0, 0, 0); }
    to {
      transform: translate3d(
        calc(var(--obs-cards) * (var(--obs-card-w) + var(--obs-card-gap)) * -1),
        0,
        0
      );
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .obs-carousel {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
    .obs-track {
      animation: none;
    }
  }
</style>
