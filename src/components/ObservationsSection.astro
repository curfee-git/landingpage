---
import Icon from '@/components/shared/Icon.astro';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const cards = [
  { icon: 'rule', title: t['observations.1.title'], text: t['observations.1.reality'] },
  { icon: 'account_tree', title: t['observations.2.title'], text: t['observations.2.reality'] },
  { icon: 'call_split', title: t['observations.3.title'], text: t['observations.3.reality'] },
  { icon: 'code', title: t['observations.7.title'], text: t['observations.7.reality'] },
  { icon: 'psychology', title: t['observations.4.title'], text: t['observations.4.reality'] },
  { icon: 'route', title: t['observations.5.title'], text: t['observations.5.reality'] },
  { icon: 'explore', title: t['observations.6.title'], text: t['observations.6.reality'] },
];

const loop = [...cards, ...cards];
---

<section id="observations" class="cf-section" aria-labelledby="observations-heading">
  <div class="cf-container">
    <div class="obs-inner">
      <p class="cf-eyebrow mb-4">{t['observations.subtitle.status_quo']}</p>
      <h2 id="observations-heading" data-speakable class="cf-h2">
        {t['observations.heading.status_quo']}
      </h2>
    </div>
  </div>

  <div class="obs-carousel" role="region" aria-label={t['observations.heading.status_quo']}>
    <ul class="obs-track" role="list">
      {loop.map((card, i) => (
        <li class="obs-card" aria-hidden={i >= cards.length ? 'true' : undefined}>
          <Icon name={card.icon} class="w-6 h-6 text-brand-primary shrink-0" />
          <h3 class="text-title-medium font-semibold text-ink-primary mt-3 mb-2">{card.title}</h3>
          <p class="text-body-medium text-ink-muted leading-relaxed">{card.text}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .obs-inner { max-width: 920px; }

  .obs-carousel {
    margin-top: 48px;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
  }

  .obs-track {
    --obs-card-w: 320px;
    --obs-card-gap: 16px;
    --obs-cards: 7;
    display: flex;
    width: max-content;
    margin: 0;
    padding: 4px 0;
    list-style: none;
    animation: obs-scroll 75s linear infinite;
    will-change: transform;
  }

  .obs-carousel:hover .obs-track,
  .obs-carousel:focus-within .obs-track {
    animation-play-state: paused;
  }

  .obs-card {
    flex: 0 0 var(--obs-card-w);
    min-height: 220px;
    margin-right: var(--obs-card-gap);
    background: rgb(var(--surface-base));
    border: 1px solid rgb(var(--ink-primary) / 0.18);
    border-radius: 8px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  @keyframes obs-scroll {
    from { transform: translate3d(0, 0, 0); }
    to {
      transform: translate3d(
        calc(var(--obs-cards) * (var(--obs-card-w) + var(--obs-card-gap)) * -1),
        0,
        0
      );
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .obs-carousel {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
    .obs-track {
      animation: none;
    }
  }
</style>
