---
import Icon from '@/components/shared/Icon.astro';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const pairs = [
  { icon: 'person_add', title: t['observations.1.title'], observation: t['observations.1'], vision: t['about.vision.1.description'] },
  { icon: 'group_work', title: t['observations.2.title'], observation: t['observations.2'], vision: t['about.vision.2.description'] },
  { icon: 'check_circle', title: t['observations.3.title'], observation: t['observations.3'], vision: t['about.vision.3.description'] },
  { icon: 'construction', title: t['observations.4.title'], observation: t['observations.4'], vision: t['about.vision.4.description'] },
  { icon: 'description', title: t['observations.5.title'], observation: t['observations.5'], vision: t['about.vision.5.description'] },
  { icon: 'swap_horiz', title: t['observations.6.title'], observation: t['observations.6'], vision: t['about.vision.6.description'] },
];
---

<section class="py-20 md:py-24" aria-labelledby="observations-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <h2 id="observations-heading" class="text-headline-large md:text-display-small text-ink-primary mb-2">{t['observations.heading']}</h2>
    <p class="text-title-medium text-brand-primary/70 font-medium mb-12">{t['observations.subtitle']}</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {pairs.map((pair) => (
        <div class="rounded-md border border-stroke-outlineVariant bg-surface-raised p-6 md:p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-brand-primary/[0.08] flex items-center justify-center flex-shrink-0">
              <Icon name={pair.icon} class="w-5 h-5 text-brand-primary" />
            </div>
            <h3 class="text-title-medium text-ink-primary">{pair.title}</h3>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <p class="text-label-medium font-bold text-ink-muted mb-1">{t['observations.column.left']}</p>
              <p class="text-body-medium text-ink-muted leading-relaxed">{pair.observation}</p>
            </div>
            <div>
              <p class="text-label-medium font-bold text-brand-primary/70 mb-1">{t['observations.column.right']}</p>
              <p class="text-body-medium text-brand-primary leading-relaxed">{pair.vision}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
