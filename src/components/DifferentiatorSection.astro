---
import Icon from '@/components/shared/Icon.astro';

const points = [
  {
    icon: 'hub',
    title: 'KI holistisch denken.',
    body: 'Technologie ist nicht neutral. Sie verändert, wie Teams zusammenarbeiten, wie Führung funktioniert, wie Entscheidungen getroffen werden.',
  },
  {
    icon: 'shield',
    title: 'Kein Hype. Keine Worthülsen.',
    body: 'Ich sage dir nicht, dass KI alles verändern wird. Ich sage dir, was KI in deiner spezifischen Situation leisten kann – und was nicht.',
  },
  {
    icon: 'handshake',
    title: 'Menschen zuerst.',
    body: 'Jede Maßnahme ist darauf ausgelegt, dass die Personen, die KI einsetzen sollen, das auch wirklich tun wollen.',
  },
];
---

<section id="differentiator" class="cf-section cf-section--navy" aria-labelledby="differentiator-heading">
  <div class="cf-container">
    <p class="cf-eyebrow">Was mich unterscheidet</p>
    <h2 id="differentiator-heading" data-speakable class="cf-h2 differentiator-title">
      Nicht mehr Beratung.<br />Sondern bessere Entscheidungen.
    </h2>

    <div class="differentiator-grid">
      {points.map((p) => (
        <div class="differentiator-item">
          <div class="differentiator-icon" aria-hidden="true">
            <Icon name={p.icon} />
          </div>
          <h3 class="differentiator-item-title">{p.title}</h3>
          <p class="differentiator-item-body">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .differentiator-title {
    color: rgb(var(--on-brand-primary));
    max-width: 560px;
    margin-top: 16px;
  }

  .differentiator-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 56px;
  }

  .differentiator-item {
    display: flex;
    flex-direction: column;
  }

  .differentiator-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgb(var(--surface-base) / 0.07);
    border: 1px solid rgb(var(--surface-base) / 0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: rgb(var(--surface-base) / 0.7);
    transition:
      background 280ms ease,
      color 280ms ease,
      transform 280ms ease,
      border-color 280ms ease;
  }
  .differentiator-icon :global(svg) {
    width: 18px;
    height: 18px;
  }
  .differentiator-item:hover .differentiator-icon {
    background: rgb(var(--surface-base) / 0.14);
    border-color: rgb(var(--surface-base) / 0.28);
    color: rgb(var(--surface-base));
    transform: scale(1.08);
  }

  .differentiator-item-title {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 1.0625rem;
    color: rgb(var(--on-brand-primary));
    letter-spacing: -0.01em;
    margin: 0 0 12px 0;
  }

  .differentiator-item-body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgb(var(--on-brand-primary) / 0.7);
    margin: 0;
  }

  @media (max-width: 900px) {
    .differentiator-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-top: 40px;
    }
  }
</style>
