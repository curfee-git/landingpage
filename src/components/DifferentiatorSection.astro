---
import Icon from '@/components/shared/Icon.astro';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();

const points = [
  { icon: 'trending_up', title: t['differentiator.1.title'], body: t['differentiator.1.body'] },
  { icon: 'visibility', title: t['differentiator.2.title'], body: t['differentiator.2.body'] },
  { icon: 'autorenew', title: t['differentiator.3.title'], body: t['differentiator.3.body'] },
];
---

<section
  id="differentiator"
  class="py-20 sm:py-26 xl:py-36 bg-brand-primary text-brand-primary-foreground"
  aria-labelledby="differentiator-heading"
>
  <div class="max-w-300 mx-auto px-gutter xl:px-0">
    <p class="font-sans text-sm font-extrabold tracking-wider uppercase text-surface-base/70 m-0">
      {t['differentiator.eyebrow']}
    </p>
    <h2
      id="differentiator-heading"
      data-speakable
      class="font-sans text-3xl md:text-4xl font-extrabold leading-none tracking-tight text-balance break-words hyphens-auto m-0 mt-4 max-w-140 text-brand-primary-foreground"
    >
      {t['differentiator.heading.1']}<br /><span class="inline-block whitespace-nowrap">{t['differentiator.heading.2']}</span>
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-x-14 lg:gap-y-5 mt-10 lg:mt-14">
      {points.map((p) => (
        <div class="group flex flex-col">
          <div class="w-10 h-10 rounded-lg bg-surface-base/7 group-hover:bg-surface-base/14 border border-surface-base/14 group-hover:border-surface-base/28 flex items-center justify-center mb-5 lg:mb-0 text-surface-base/70 group-hover:text-surface-base group-hover:scale-108 transition-all duration-300">
            <Icon name={p.icon} class="w-4.5 h-4.5" />
          </div>
          <h3 class="font-sans font-extrabold text-lg tracking-tight m-0 mb-3 lg:mb-0 text-brand-primary-foreground">
            {p.title}
          </h3>
          <p class="font-sans text-base leading-relaxed text-brand-primary-foreground/70 m-0">
            {p.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

