---
import { Image } from 'astro:assets';
import Icon from '@/components/shared/Icon.astro';
import { getRoutes } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';
import diagnosisImage from '@/assets/images/diagnosis_section_image.png';
import guidanceBackground from '@/assets/images/guidance_background_gray.png';
import advisoryBackground from '@/assets/images/advisory_background_gray.png';
import guidanceOverlay from '@/assets/images/guidance_overlay_blue.png';
import advisoryOverlay from '@/assets/images/advisory_overlay_blue.png';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();

const services = [
  {
    key: 'diagnosis' as const,
    title: t['services.diagnosis.title'],
    subtitle: t['services.diagnosis.subtitle'],
    duration: t['services.diagnosis.duration'],
    problem: t['services.diagnosis.problem'],
    cta: t['services.card.cta'],
    image: diagnosisImage,
    overlay: null,
    imageAlt: t['services.diagnosis.image.alt'],
    accent: 'primary',
  },
  {
    key: 'guidance' as const,
    title: t['services.guidance.title'],
    subtitle: t['services.guidance.subtitle'],
    duration: t['services.guidance.duration'],
    problem: t['services.guidance.problem'],
    cta: t['services.card.cta'],
    image: guidanceBackground,
    overlay: guidanceOverlay,
    imageAlt: t['services.guidance.image.alt'],
    accent: 'secondary',
  },
  {
    key: 'advisory' as const,
    title: t['services.advisory.title'],
    subtitle: t['services.advisory.subtitle'],
    duration: t['services.advisory.duration'],
    problem: t['services.advisory.problem'],
    cta: t['services.card.cta'],
    image: advisoryBackground,
    overlay: advisoryOverlay,
    imageAlt: t['services.advisory.image.alt'],
    accent: 'tertiary',
  },
];
---

<section id="services" class="cf-section cf-section--soft" aria-labelledby="services-heading">
  <div class="cf-container">

    <header class="services-head">
      <p class="cf-eyebrow">Wie ich arbeite</p>
      <h2 id="services-heading" data-speakable class="cf-h2">{t['services.heading']}</h2>
      <p class="cf-lead" style="margin-top: 16px; max-width: 640px;">{t['services.subtitle']}</p>
    </header>

    <div class="cf-grid-3 services-grid">
      {services.map((service) => (
        <a href={routes.service[service.key]} class={`service-card service-card--${service.accent}`} aria-label={`Mehr lesen: ${service.title}`}>
          {service.image && (
            <div class="service-card-image">
              <Image
                src={service.image}
                alt={service.imageAlt ?? ''}
                loading="lazy"
                decoding="async"
                width={800}
                height={500}
                widths={[400, 600, 800, 1200]}
                sizes="(min-width: 1024px) 360px, (min-width: 641px) 50vw, 100vw"
              />
              {service.overlay && (
                <Image
                  class="service-card-overlay"
                  src={service.overlay}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width={800}
                  height={500}
                  widths={[400, 600, 800, 1200]}
                  sizes="(min-width: 1024px) 360px, (min-width: 641px) 50vw, 100vw"
                />
              )}
            </div>
          )}
          <p class="cf-eyebrow service-duration">{service.duration}</p>
          <h3 class="cf-h3 service-title">{service.title}</h3>
          <p class="service-subtitle">{service.subtitle}</p>
          <p class="service-problem">{service.problem}</p>
          <span class="service-link">
            {service.cta}
            <Icon name="arrow_right_alt" class="w-4 h-4" />
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .services-head { max-width: 640px; margin-bottom: 56px; }
  .services-head .cf-eyebrow { margin-bottom: 16px; }

  .service-card {
    display: flex;
    flex-direction: column;
    background: rgb(var(--surface-base));
    border: 1px solid rgb(var(--ink-primary) / 0.1);
    border-radius: 8px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: transform 200ms ease;
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 641px) {
    .service-card { padding: 32px; }
  }
  .service-card:hover {
    transform: translateY(-4px);
  }

  .service-card-image {
    margin: -24px -24px 20px;
    aspect-ratio: 1586 / 992;
    overflow: hidden;
    position: relative;
  }
  .service-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .service-card-image .service-card-overlay {
    position: absolute;
    inset: 0;
  }
  @media (min-width: 641px) {
    .service-card-image { margin: -32px -32px 24px; }
  }


  .service-duration {
    margin-bottom: 12px;
  }

  .service-title {
    margin-bottom: 8px;
    color: rgb(var(--ink-primary));
    font-weight: 800;
  }

  .service-subtitle {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0 0 16px 0;
    color: rgb(var(--brand-primary));
    font-weight: 700;
  }

  .service-problem {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--ink-primary) / 0.75);
    margin: 0 0 24px 0;
    flex: 1;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 700;
    margin-top: auto;
    color: rgb(var(--brand-primary));
    align-self: flex-start;
  }

</style>
