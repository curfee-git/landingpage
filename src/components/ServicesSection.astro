---
import { Image } from 'astro:assets';
import Icon from '@/components/shared/Icon.astro';
import { getRoutes } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';
import sectionBackground from '@/assets/images/section_image_background.png';
import diagnosisOverlay from '@/assets/images/diagnosis_overlay.png';
import guidanceOverlay from '@/assets/images/guidance_overlay.png';
import advisoryOverlay from '@/assets/images/advisory_overlay.png';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();

const services = [
  {
    key: 'diagnosis' as const,
    title: t['services.diagnosis.title'],
    subtitle: t['services.diagnosis.subtitle'],
    problem: t['services.diagnosis.problem'],
    cta: t['services.card.cta'],
    image: sectionBackground,
    overlay: diagnosisOverlay,
    imageAlt: t['services.diagnosis.image.alt'],
  },
  {
    key: 'guidance' as const,
    title: t['services.guidance.title'],
    subtitle: t['services.guidance.subtitle'],
    problem: t['services.guidance.problem'],
    cta: t['services.card.cta'],
    image: sectionBackground,
    overlay: guidanceOverlay,
    imageAlt: t['services.guidance.image.alt'],
  },
  {
    key: 'advisory' as const,
    title: t['services.advisory.title'],
    subtitle: t['services.advisory.subtitle'],
    problem: t['services.advisory.problem'],
    cta: t['services.card.cta'],
    image: sectionBackground,
    overlay: advisoryOverlay,
    imageAlt: t['services.advisory.image.alt'],
  },
];
---

<section
  id="services"
  class="py-20 sm:py-[104px] xl:py-[144px] bg-surface-soft"
  aria-labelledby="services-heading"
>
  <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">

    <header class="max-w-[640px] mb-14">
      <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0 mb-4">
        {t['services.eyebrow']}
      </p>
      <h2
        id="services-heading"
        data-speakable
        class="font-sans text-3xl md:text-4xl font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0"
      >
        {t['services.heading']}
      </h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-[auto_auto_auto_auto_auto] gap-6">
      {services.map((service) => (
        <a
          href={routes.service[service.key]}
          aria-label={`${t['services.aria.read_more']} ${service.title}`}
          class="group relative flex flex-col md:grid md:grid-rows-subgrid md:row-span-5 bg-surface-base border border-ink-primary/10 rounded-md p-6 sm:p-8 no-underline text-inherit overflow-hidden transition-transform duration-200 hover:-translate-y-1"
        >
          {service.image && (
            <div class="-mx-3 sm:-mx-4 -mt-3 sm:-mt-4 mb-5 sm:mb-6 aspect-[1586/992] overflow-hidden relative">
              <Image
                src={service.image}
                alt={service.imageAlt ?? ''}
                loading="lazy"
                decoding="async"
                width={800}
                height={500}
                widths={[400, 600, 800, 1200]}
                sizes="(min-width: 1024px) 360px, (min-width: 641px) 50vw, 100vw"
                class="w-full h-full object-cover block"
              />
              {service.overlay && (
                <Image
                  class="absolute inset-0 w-full h-full object-cover block"
                  src={service.overlay}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width={800}
                  height={500}
                  widths={[400, 600, 800, 1200]}
                  sizes="(min-width: 1024px) 360px, (min-width: 641px) 50vw, 100vw"
                />
              )}
            </div>
          )}
          <h3 class="font-sans text-xl md:text-2xl font-extrabold leading-tight tracking-[-0.005em] break-words hyphens-auto m-0 mb-2 text-ink-primary">
            {service.title}
          </h3>
          <p class="font-sans text-[0.9375rem] leading-[1.5] text-brand-primary font-bold m-0 mb-4">
            {service.subtitle}
          </p>
          <p class="font-sans text-[0.9375rem] leading-[1.6] text-ink-muted m-0 mb-6 flex-1">
            {service.problem}
          </p>
          <span class="inline-flex items-center gap-1.5 mt-auto self-start font-sans text-[0.875rem] font-bold text-brand-primary">
            {service.cta}
            <Icon name="arrow_right_alt" class="w-4 h-4" />
          </span>
        </a>
      ))}
    </div>

  </div>
</section>
