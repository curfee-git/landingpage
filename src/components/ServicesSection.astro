---
import Icon from '@/components/shared/Icon.astro';
import { getRoutes } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes(Astro.currentLocale);

const services = [
  {
    key: 'diagnosis' as const,
    icon: 'search',
    title: t['services.diagnosis.title'],
    subtitle: t['services.diagnosis.subtitle'],
    duration: t['services.diagnosis.duration'],
    problem: t['services.diagnosis.problem'],
    cta: t['services.diagnosis.cta'],
    accent: 'primary',
  },
  {
    key: 'guidance' as const,
    icon: 'route',
    title: t['services.guidance.title'],
    subtitle: t['services.guidance.subtitle'],
    duration: t['services.guidance.duration'],
    problem: t['services.guidance.problem'],
    cta: t['services.guidance.cta'],
    accent: 'secondary',
  },
  {
    key: 'advisory' as const,
    icon: 'handshake',
    title: t['services.advisory.title'],
    subtitle: t['services.advisory.subtitle'],
    duration: t['services.advisory.duration'],
    problem: t['services.advisory.problem'],
    cta: t['services.advisory.cta'],
    accent: 'tertiary',
  },
];
---

<section id="services" class="uc-section" aria-labelledby="services-heading">
  <div class="uc-container">

    <header class="services-head">
      <p class="uc-eyebrow">Services</p>
      <h2 id="services-heading" data-speakable class="uc-h2">{t['services.heading']}</h2>
      <p class="uc-lead" style="margin-top: 16px; max-width: 640px;">{t['services.subtitle']}</p>
    </header>

    <div class="uc-grid-3 services-grid">
      {services.map((service) => (
        <a href={routes.service[service.key]} class={`service-card service-card--${service.accent}`} aria-label={`Read more: ${service.title}`}>
          <div class="service-icon">
            <Icon name={service.icon} class="w-6 h-6" />
          </div>
          <p class="uc-eyebrow service-duration">{service.duration}</p>
          <h3 class="uc-h3 service-title">{service.title}</h3>
          <p class="service-subtitle">{service.subtitle}</p>
          <p class="service-problem">{service.problem}</p>
          <span class="service-link">
            {service.cta}
            <Icon name="arrow_outward" class="w-4 h-4" />
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .services-head { max-width: 640px; margin-bottom: 56px; }
  .services-head .uc-eyebrow { margin-bottom: 16px; }

  .service-card {
    display: flex;
    flex-direction: column;
    background: rgb(var(--surface-base));
    border: 1px solid rgb(var(--stroke-subtle));
    border-radius: 12px;
    padding: 32px;
    text-decoration: none;
    color: inherit;
    transition: border-color 140ms cubic-bezier(0.22, 1, 0.36, 1), transform 140ms cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
  }
  .service-card:hover {
    transform: translateY(-2px);
  }

  .service-card--primary:hover { border-color: rgb(var(--brand-primary)); }
  .service-card--secondary:hover { border-color: rgb(var(--brand-secondary)); }
  .service-card--tertiary:hover { border-color: rgb(var(--brand-tertiary)); }

  .service-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .service-card--primary .service-icon { background: rgb(var(--brand-primary) / 0.1); color: rgb(var(--brand-primary)); }
  .service-card--secondary .service-icon { background: rgb(var(--brand-secondary) / 0.1); color: rgb(var(--brand-secondary)); }
  .service-card--tertiary .service-icon { background: rgb(var(--brand-tertiary) / 0.1); color: rgb(var(--brand-tertiary)); }

  .service-duration {
    margin-bottom: 8px;
  }

  .service-title {
    margin-bottom: 4px;
    color: rgb(var(--ink-primary));
  }

  .service-subtitle {
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0 0 16px 0;
    color: rgb(var(--ink-primary));
    font-weight: 600;
  }
  .service-card--primary .service-subtitle { color: rgb(var(--brand-primary)); }
  .service-card--secondary .service-subtitle { color: rgb(var(--brand-secondary)); }
  .service-card--tertiary .service-subtitle { color: rgb(var(--brand-tertiary)); }

  .service-problem {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--ink-muted));
    margin: 0 0 24px 0;
    flex: 1;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-top: auto;
  }
  .service-card--primary .service-link { color: rgb(var(--brand-primary)); }
  .service-card--secondary .service-link { color: rgb(var(--brand-secondary)); }
  .service-card--tertiary .service-link { color: rgb(var(--brand-tertiary)); }

  @media (max-width: 640px) {
    .service-card { padding: 24px; }
  }
</style>
