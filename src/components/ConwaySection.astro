---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
---

<section
  id="conway"
  class="py-20 sm:py-[104px] xl:py-[144px]"
  aria-labelledby="conway-heading"
>
  <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
    <p
      id="conway-heading"
      class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0 mb-5"
    >
      {t['conway.eyebrow']}
    </p>
    <figure class="m-0 border-l-[3px] border-brand-primary py-2 pl-6 md:pl-8">
      <blockquote data-speakable class="m-0">
        <p class="font-sans font-bold text-[clamp(1.25rem,2.5vw,1.75rem)] leading-[1.3] tracking-[-0.01em] text-ink-primary text-balance m-0">
          {t['conway.quote']}
        </p>
      </blockquote>
      <figcaption class="flex items-baseline gap-2 mt-4 font-sans">
        <span class="text-[0.875rem] font-semibold text-brand-primary tracking-[0.04em]">
          {t['conway.attribution']}
        </span>
      </figcaption>
    </figure>
  </div>
</section>
