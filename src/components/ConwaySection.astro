---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
---

<section
  id="conway"
  class="py-20 sm:py-26 xl:py-36"
  aria-labelledby="conway-heading"
>
  <div class="max-w-300 mx-auto px-gutter xl:px-0">
    <p
      id="conway-heading"
      class="font-sans text-sm font-extrabold tracking-wider uppercase text-brand-primary m-0 mb-5"
    >
      {t['conway.eyebrow']}
    </p>
    <figure class="m-0 border-l-4 border-brand-primary py-2 pl-6 md:pl-8">
      <blockquote data-speakable class="m-0">
        <p class="font-sans font-bold text-xl md:text-2xl leading-tight tracking-tight text-ink-primary text-balance m-0">
          {t['conway.quote']}
        </p>
      </blockquote>
      <figcaption class="flex items-baseline gap-2 mt-4 font-sans">
        <span class="text-sm font-semibold text-brand-primary tracking-wider">
          {t['conway.attribution']}
        </span>
      </figcaption>
    </figure>
  </div>
</section>
