---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const hasHeading = Boolean(t['casestudy.heading']);
const hasSubtitle = Boolean(t['casestudy.subtitle']);
const hasPlaceholder = Boolean(t['casestudy.placeholder']);
---

{(hasHeading || hasSubtitle || hasPlaceholder) && (
  <section id="casestudy" class="uc-section" aria-labelledby="casestudy-heading">
    <div class="uc-container">
      <div style="max-width: 920px;">
        <p class="uc-eyebrow" style="margin-bottom: 16px;">Case Studies</p>
        {hasHeading && (
          <h2 id="casestudy-heading" class="uc-h2">{t['casestudy.heading']}</h2>
        )}
        {hasSubtitle && (
          <p class="uc-lead" style="margin-top: 16px; color: rgb(var(--brand-primary)); font-weight: 600; max-width: 640px;">{t['casestudy.subtitle']}</p>
        )}
        {hasPlaceholder && (
          <div class="uc-card" style="margin-top: 40px;">
            <p class="uc-body" style="font-style: italic;">
              {t['casestudy.placeholder']}
            </p>
          </div>
        )}
      </div>
    </div>
  </section>
)}
