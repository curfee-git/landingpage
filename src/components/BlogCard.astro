---
import { postPath, formatDate, type BlogPost } from '@/content/_posts';

interface Props {
  post: BlogPost;
  index: number;
  headingLevel?: 'h2' | 'h3';
}

const { post, index, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<a
  href={postPath(post)}
  data-astro-reload
  class="group flex h-full flex-col rounded-lg bg-surface-base border border-stroke-subtle p-6 md:p-8 transition-transform duration-short4 ease-standard hover:-translate-y-1"
>
  <div class="flex items-center justify-between mb-5">
    <span class="text-headline-small text-brand-primary font-extrabold tabular-nums leading-none" data-card-number>
      {String(index).padStart(2, '0')}
    </span>
    <time class="text-body-small text-ink-meta tabular-nums" datetime={post.data.createdAt.toISOString()}>
      {formatDate(post.data.createdAt)}
    </time>
  </div>
  <Heading class="font-sans font-extrabold text-[1.25rem] leading-[1.2] tracking-tight text-ink-primary mb-3">
    {post.data.title}
  </Heading>
  <p class="text-body-medium text-ink-muted leading-relaxed mb-6 flex-1">
    {post.data.excerpt}
  </p>
  <div class="flex justify-end">
    <span class="inline-flex items-center rounded-xs border border-stroke-subtle text-label-small font-semibold tracking-wider uppercase text-ink-soft px-2 py-1">
      {post.data.topic}
    </span>
  </div>
</a>
