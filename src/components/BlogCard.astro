---
import { postPath, formatDate, type BlogPost } from '@/content/_posts';

interface Props {
  post: BlogPost;
  index: number;
  headingLevel?: 'h2' | 'h3';
}

const { post, index, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<a
  href={postPath(post)}
  data-astro-reload
  class="group flex h-full flex-col rounded-xl bg-surface-base border border-stroke-subtle p-6 md:p-8 hover:border-brand-primary/60 transition-colors duration-medium2 ease-standard"
>
  <div class="flex items-center justify-between mb-5">
    <span class="text-headline-small text-brand-primary/40 font-semibold tabular-nums leading-none" data-card-number>
      {String(index).padStart(2, '0')}
    </span>
    <time class="text-body-small text-ink-muted/60 tabular-nums" datetime={post.data.createdAt.toISOString()}>
      {formatDate(post.data.createdAt)}
    </time>
  </div>
  <Heading class="text-title-large text-ink-primary mb-3 tracking-tight">
    {post.data.title}
  </Heading>
  <p class="text-body-medium text-ink-muted leading-relaxed mb-6 flex-1">
    {post.data.excerpt}
  </p>
  <div class="flex justify-end">
    <span class="inline-flex items-center rounded-full border border-stroke-outlineVariant/70 text-label-small leading-none text-ink-muted/80 px-2 py-1">
      {post.data.topic}
    </span>
  </div>
</a>
