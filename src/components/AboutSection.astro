---
import { Image } from 'astro:assets';
import type { Translations } from '@/i18n/translations';
import profileImage from '@/assets/images/profile.png';
import { EXTERNAL, getRoutes } from '@/configurations/routes';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();

const credentials = [
  {
    mark: 'L',
    title: 'Wurzeln in der Logistik',
    body: 'Mein Werdegang begann in der Logistik: Workflows zwischen Waren, Menschen und Prozessen koordinieren. Dort habe ich gelernt, dass verlässliche Strukturen den Unterschied machen zwischen einem Prozess, der läuft, und einem, der bricht.',
  },
  {
    mark: 'I',
    title: 'Informatik → Architektur',
    body: 'Nach meinem Studium ging es in die Softwareentwicklung, dann in die Architektur. Über Automotive, öffentlichen Sektor und Software-Beratung hinweg habe ich das große Bild und die kleinen Details gleichzeitig im Blick behalten.',
  },
  {
    mark: 'K',
    title: 'Systeme im KI-Zeitalter',
    body: 'KI sieht nur, was in ihr Kontextfenster passt, und bringt keine eigene Struktur mit. Grenzen müssen vom System selbst durchgesetzt werden — und das funktioniert nur, wenn die Struktur dahinter verlässlich ist.',
  },
  {
    mark: 'E',
    title: 'Eigenständige Praxis',
    body: 'Über die Curfee e.U. arbeite ich direkt mit Gründern, CTOs und Engineering-Managern in der DACH-Region. Keine Zwischenebenen, keine Account-Manager, nur die Arbeit.',
  },
  {
    mark: 'D',
    title: 'Prinzip der Entscheidungsdurchsetzung',
    body: 'Mein Kernprinzip: Entscheidungen sollten vom System selbst durchgesetzt werden — über Pipelines, automatisierte Checks und Tool-Konfiguration. Nicht durch individuelle Disziplin, Erinnerung oder Wachsamkeit.',
  },
  {
    mark: 'S',
    title: 'Mit Sitz in Salzburg, Österreich',
    body: 'Tätig in der gesamten DACH-Region. Remote-Engagements sind Standard; Vor-Ort-Termine, wenn die Arbeit es erfordert.',
  },
];
---

<article class="about-page">

  <!-- Hero -->
  <section class="uc-section about-hero" aria-labelledby="about-hero-heading">
    <div class="uc-container">
      <div class="about-hero-grid">
        <div class="about-hero-text">
          <p class="uc-eyebrow">Über mich</p>
          <h1 id="about-hero-heading" class="about-hero-title">Ich bin {t['about.heading']}.</h1>
          <p class="about-hero-jobtitle">
            {t['about.who.heading']}<br />
            <span>Strukturarchitekt · Gründer, Curfee e.U.</span>
          </p>
          <p class="about-hero-body">{t['about.who.1']}</p>
          <p class="about-hero-emphasis">{t['about.who.6']}</p>

          <div class="about-hero-ctas">
            <a href={routes.contact} class="about-btn about-btn--primary">{t['hero.cta']}</a>
            <a href={EXTERNAL.linkedin} target="_blank" rel="noopener noreferrer" class="about-btn about-btn--outline">Auf LinkedIn folgen</a>
          </div>
        </div>

        <div class="about-hero-aside">
          <div class="about-portrait-wrap">
            <Image src={profileImage} alt={t['about.portrait.alt']} class="about-portrait" loading="eager" decoding="async" width={400} height={600} widths={[280, 400, 600, 800]} sizes="(max-width: 900px) 280px, 400px" />
          </div>
          <div class="about-claim">
            <p>"{t['about.who.2']}"</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Curfee -->
  <section class="uc-section uc-section--soft" aria-labelledby="why-heading">
    <div class="uc-container">
      <div class="uc-grid-2-3">
        <div>
          <p class="uc-eyebrow">Warum Curfee</p>
          <h2 id="why-heading" class="uc-h2">{t['about.section.why']}</h2>
        </div>
        <div class="about-prose">
          <p>{t['about.who.5']}</p>
          <p>{t['about.who.5b']}</p>
          <p>{t['about.who.3b']}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials grid -->
  <section class="uc-section" aria-labelledby="background-heading">
    <div class="uc-container">
      <div class="about-credentials-head">
        <p class="uc-eyebrow">{t['about.section.background']}</p>
        <h2 id="background-heading" class="uc-h2">Was meinen Ansatz geprägt hat</h2>
        <p class="uc-lead" style="margin-top: 16px; max-width: 640px;">Keine Liste von Titeln, sondern Kontext für die Arbeit, die ich mache.</p>
      </div>
      <div class="about-credentials">
        {credentials.map((c) => (
          <div class="credential">
            <div class="credential-mark" aria-hidden="true">{c.mark}</div>
            <div class="credential-body">
              <h3 class="credential-title">{c.title}</h3>
              <p class="credential-text">{c.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="uc-section uc-section--soft" aria-labelledby="principles-heading">
    <div class="uc-container">
      <div class="about-principles-head">
        <p class="uc-eyebrow">Drei leitende Prinzipien</p>
        <h2 id="principles-heading" class="uc-h2">Wie ich arbeite</h2>
      </div>
      <div class="about-principles-grid">
        <div class="principle">
          <span class="principle-num">01</span>
          <h3 class="principle-title">{t['principles.1']}</h3>
          <p class="principle-text">Symptome zeigen den Weg. Ursachen lösen. Die Arbeit beginnt dort, wo die Kette endet.</p>
        </div>
        <div class="principle">
          <span class="principle-num">02</span>
          <h3 class="principle-title">{t['principles.2']}</h3>
          <p class="principle-text">Ein Standard, der von individueller Wachsamkeit abhängt, ist ein Standard, der irgendwann driftet. Das System muss ihn durchsetzen.</p>
        </div>
        <div class="principle">
          <span class="principle-num">03</span>
          <h3 class="principle-title">{t['principles.3']}</h3>
          <p class="principle-text">Workarounds summieren sich zu einer Struktur, die niemand gewählt hat. Bau das Fundament, dann bleibt alles darüber gerade.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="uc-section uc-section--navy">
    <div class="uc-container">
      <div style="max-width: 760px;">
        <h2 class="uc-h2" style="color: rgb(var(--on-brand-primary));">{t['calltoaction.heading']}</h2>
        <p class="uc-lead" style="margin-top: 16px; max-width: 640px; color: rgb(var(--on-brand-primary) / 0.85);">{t['calltoaction.subtitle']}</p>
        <a href={routes.contact} class="about-final-cta">{t['hero.cta']}</a>
      </div>
    </div>
  </section>

</article>

<style>
  /* === Hero === */
  .about-hero {
    padding-top: 80px;
  }
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 80px;
    align-items: start;
  }
  .about-hero-text {
    max-width: 640px;
  }
  .about-hero-title {
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 16px 0 0 0;
  }
  .about-hero-jobtitle {
    font-weight: 600;
    font-size: 1rem;
    color: rgb(var(--brand-primary));
    margin: 16px 0 28px 0;
    letter-spacing: 0.01em;
    line-height: 1.5;
  }
  .about-hero-jobtitle span {
    font-weight: 500;
    color: rgb(var(--ink-muted));
  }
  .about-hero-body {
    font-size: 1.0625rem;
    color: rgb(var(--ink-muted));
    line-height: 1.75;
    margin: 0 0 20px 0;
  }
  .about-hero-emphasis {
    font-size: 1.0625rem;
    line-height: 1.75;
    font-weight: 600;
    color: rgb(var(--brand-primary));
    margin: 0;
  }
  .about-hero-ctas {
    margin-top: 36px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .about-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 24px;
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    border-radius: 8px;
    text-decoration: none;
    transition: all 140ms cubic-bezier(0.22, 1, 0.36, 1);
    border: 1px solid transparent;
  }
  .about-btn--primary {
    background: rgb(var(--brand-primary));
    color: rgb(var(--on-brand-primary));
  }
  .about-btn--primary:hover {
    filter: brightness(1.1);
  }
  .about-btn--outline {
    background: transparent;
    color: rgb(var(--ink-primary));
    border-color: rgb(var(--stroke-subtle));
  }
  .about-btn--outline:hover {
    border-color: rgb(var(--brand-primary));
    color: rgb(var(--brand-primary));
  }

  .about-hero-aside {
    display: flex;
    flex-direction: column;
  }
  .about-portrait-wrap {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: rgb(var(--surface-container-low));
  }
  :global(.about-portrait) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .about-claim {
    margin-top: 20px;
    padding: 20px 24px;
    background: rgb(var(--ink-primary));
    border-radius: 8px;
  }
  .about-claim p {
    font-weight: 700;
    font-size: 0.9375rem;
    color: rgb(var(--surface-base));
    line-height: 1.5;
    font-style: italic;
    margin: 0;
  }

  /* === Why section prose === */
  .about-prose p {
    font-size: 1.0625rem;
    color: rgb(var(--ink-muted));
    line-height: 1.75;
    margin: 0 0 20px 0;
  }
  .about-prose p:last-child {
    margin-bottom: 0;
  }

  /* === Credentials === */
  .about-credentials-head {
    max-width: 720px;
    margin-bottom: 56px;
  }
  .about-credentials {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 64px;
  }
  .credential {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 20px;
    align-items: start;
  }
  .credential-mark {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgb(var(--brand-primary));
    color: rgb(var(--on-brand-primary));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Inter", sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
  }
  .credential:nth-child(2) .credential-mark { background: rgb(var(--brand-secondary)); color: rgb(var(--on-brand-secondary)); }
  .credential:nth-child(3) .credential-mark { background: rgb(var(--brand-tertiary)); color: rgb(var(--on-brand-tertiary)); }
  .credential:nth-child(4) .credential-mark { background: rgb(var(--brand-primary)); color: rgb(var(--on-brand-primary)); }
  .credential:nth-child(5) .credential-mark { background: rgb(var(--brand-secondary)); color: rgb(var(--on-brand-secondary)); }
  .credential:nth-child(6) .credential-mark { background: rgb(var(--brand-tertiary)); color: rgb(var(--on-brand-tertiary)); }

  .credential-title {
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: rgb(var(--ink-primary));
    margin: 0 0 8px 0;
    line-height: 1.3;
  }
  .credential-text {
    font-size: 0.9375rem;
    color: rgb(var(--ink-muted));
    line-height: 1.6;
    margin: 0;
  }

  /* === Principles === */
  .about-principles-head {
    max-width: 640px;
    margin-bottom: 48px;
  }
  .about-principles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .principle {
    background: rgb(var(--surface-base));
    border: 1px solid rgb(var(--stroke-subtle));
    border-radius: 12px;
    padding: 28px;
  }
  .principle-num {
    display: inline-block;
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: rgb(var(--brand-primary));
    margin-bottom: 16px;
  }
  .principle-title {
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: rgb(var(--ink-primary));
    margin: 0 0 8px 0;
    line-height: 1.3;
  }
  .principle-text {
    font-size: 0.9375rem;
    color: rgb(var(--ink-muted));
    line-height: 1.6;
    margin: 0;
  }

  /* === Final CTA === */
  .about-final-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    padding: 14px 28px;
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    background: rgb(var(--on-brand-primary));
    color: rgb(var(--brand-primary));
    border-radius: 8px;
    text-decoration: none;
    transition: filter 140ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .about-final-cta:hover {
    filter: brightness(0.92);
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .about-hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .about-hero-aside {
      max-width: 360px;
    }
    .about-credentials {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .about-principles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
