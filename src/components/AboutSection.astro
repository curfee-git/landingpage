---
import { Image } from 'astro:assets';
import type { Translations } from '@/i18n/translations';
import profileImage from '@/assets/images/profile.png';
import { EXTERNAL, getRoutes } from '@/configurations/routes';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const routes = getRoutes();

const credentials = [
  { mark: 'L', title: t['about.credentials.1.title'], body: t['about.credentials.1.body'] },
  { mark: 'I', title: t['about.credentials.2.title'], body: t['about.credentials.2.body'] },
  { mark: 'K', title: t['about.credentials.3.title'], body: t['about.credentials.3.body'] },
  { mark: 'E', title: t['about.credentials.4.title'], body: t['about.credentials.4.body'] },
  { mark: 'D', title: t['about.credentials.5.title'], body: t['about.credentials.5.body'] },
  { mark: 'S', title: t['about.credentials.6.title'], body: t['about.credentials.6.body'] },
];

const curfeeLetters = [
  { letter: 'C', word: t['about.curfee.c.word'], text: t['about.curfee.c.text'] },
  { letter: 'U', word: t['about.curfee.u.word'], text: t['about.curfee.u.text'] },
  { letter: 'R', word: t['about.curfee.r.word'], text: t['about.curfee.r.text'] },
  { letter: 'F', word: t['about.curfee.f.word'], text: t['about.curfee.f.text'] },
  { letter: 'E', word: t['about.curfee.e1.word'], text: t['about.curfee.e1.text'] },
  { letter: 'E', word: t['about.curfee.e2.word'], text: t['about.curfee.e2.text'] },
];
---

<article>

  <!-- Hero -->
  <section class="pt-20 pb-20 sm:py-[104px] xl:py-[144px]" aria-labelledby="about-hero-heading">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_400px] lg:gap-20 items-start">
        <div class="max-w-[640px]">
          <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0">
            {t['about.eyebrow']}
          </p>
          <h1
            id="about-hero-heading"
            class="font-sans text-[clamp(2.25rem,5vw,3.75rem)] font-extrabold leading-[1.05] tracking-[-0.02em] m-0 mt-4"
          >
            {t['about.intro.greeting']} {t['about.heading']}.
          </h1>
          <p class="font-sans font-bold text-base text-brand-primary leading-[1.5] mt-4 mb-7">
            {t['about.who.heading']}<br />
            <span class="font-medium text-ink-primary/65">{t['about.jobtitle.subline']}</span>
          </p>
          <p class="font-sans text-[1.0625rem] text-ink-muted leading-[1.6] m-0 mb-5 max-w-[65ch]">
            {t['about.who.1']}
          </p>
          <p class="font-sans text-[1.0625rem] text-ink-muted leading-[1.6] m-0 mb-5 max-w-[65ch]">
            {t['about.who.1b']}
          </p>
          <p class="font-sans text-[1.0625rem] leading-[1.6] font-bold text-brand-primary m-0 max-w-[65ch]">
            {t['about.who.6']}
          </p>

          <div class="mt-9 flex flex-wrap gap-4">
            <a
              href={routes.contact}
              class="inline-flex items-center justify-center px-6 py-3.5 font-sans text-[0.9375rem] font-bold rounded-md no-underline border-[1.5px] transition-colors duration-200 bg-brand-primary text-brand-onPrimary border-brand-primary hover:bg-[#002952] hover:border-[#002952]"
            >
              {t['hero.cta']}
            </a>
            <a
              href={EXTERNAL.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-6 py-3.5 font-sans text-[0.9375rem] font-bold rounded-md no-underline border-[1.5px] transition-colors duration-200 bg-transparent text-brand-primary border-brand-primary hover:bg-brand-primary hover:text-brand-onPrimary"
            >
              {t['about.linkedin.cta']}
            </a>
          </div>
        </div>

        <div class="flex flex-col max-w-[360px] lg:max-w-none">
          <div class="rounded-lg overflow-hidden aspect-[3/4] bg-surface-soft">
            <Image
              src={profileImage}
              alt={t['about.portrait.alt']}
              class="w-full h-full object-cover object-[center_top] block"
              loading="eager"
              decoding="async"
              width={400}
              height={600}
              widths={[280, 400, 600, 800]}
              sizes="(max-width: 900px) 280px, 400px"
            />
          </div>
          <div class="mt-5 py-6 px-7 bg-surface-soft border-l-2 border-brand-primary rounded-md">
            <p class="font-sans font-semibold text-[1.0625rem] text-ink-primary leading-[1.5] m-0">
              "{t['about.who.2']}"
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Curfee -->
  <section class="py-20 sm:py-[104px] xl:py-[144px] bg-surface-soft" aria-labelledby="why-heading">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-[2fr_3fr] lg:gap-16">
        <div>
          <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0">
            {t['about.why.eyebrow']}
          </p>
          <h2
            id="why-heading"
            class="font-sans text-[clamp(1.75rem,3vw,2.5rem)] font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 mt-2"
          >
            {t['about.section.why']}
          </h2>
        </div>
        <div>
          <p class="font-sans text-[1.0625rem] text-ink-muted leading-[1.6] m-0 mb-5 max-w-[65ch]">{t['about.who.5']}</p>
          <p class="font-sans text-[1.0625rem] text-ink-muted leading-[1.6] m-0 mb-5 max-w-[65ch]">{t['about.who.5b']}</p>
          <p class="font-sans text-[1.0625rem] text-ink-muted leading-[1.6] m-0 mb-5 max-w-[65ch]">{t['about.who.3b']}</p>
          <p class="font-sans text-[1.0625rem] leading-[1.6] font-bold text-brand-primary m-0 max-w-[65ch]">{t['about.who.5c']}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials grid -->
  <section class="py-20 sm:py-[104px] xl:py-[144px]" aria-labelledby="background-heading">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="max-w-[720px] mb-14">
        <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0">
          {t['about.section.background']}
        </p>
        <h2
          id="background-heading"
          class="font-sans text-[clamp(1.75rem,3vw,2.5rem)] font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 mt-4"
        >
          {t['about.background.heading']}
        </h2>
        <p class="font-sans text-[1.125rem] leading-[1.6] text-ink-muted max-w-[640px] font-medium mt-4">
          {t['about.background.lead']}
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-x-16 lg:gap-y-12">
        {credentials.map((c) => (
          <div class="grid grid-cols-[56px_1fr] gap-5 items-start">
            <div
              class="w-12 h-12 rounded-xs bg-brand-primary text-brand-onPrimary flex items-center justify-center font-sans font-extrabold text-[1.25rem]"
              aria-hidden="true"
            >
              {c.mark}
            </div>
            <div>
              <h3 class="font-sans text-[1.125rem] font-bold text-ink-primary m-0 mb-2 leading-[1.3]">
                {c.title}
              </h3>
              <p class="font-sans text-[0.9375rem] text-ink-muted leading-[1.6] m-0 max-w-[65ch]">
                {c.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="py-20 sm:py-[104px] xl:py-[144px] bg-surface-soft" aria-labelledby="principles-heading">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="max-w-[640px] mb-12">
        <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0">
          {t['about.principles.eyebrow']}
        </p>
        <h2
          id="principles-heading"
          class="font-sans text-[clamp(1.75rem,3vw,2.5rem)] font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 mt-4"
        >
          {t['about.principles.heading']}
        </h2>
      </div>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="bg-surface-base border border-ink-primary/10 rounded-md p-8 transition-transform duration-200 hover:-translate-y-1">
          <span class="inline-block font-sans text-[0.8125rem] font-semibold tracking-[0.06em] text-brand-primary mb-4">01</span>
          <h3 class="font-sans text-[1.25rem] font-bold text-ink-primary m-0 mb-2 leading-[1.3]">{t['principles.1']}</h3>
          <p class="font-sans text-[0.9375rem] text-ink-muted leading-[1.6] m-0">{t['about.principles.1.text']}</p>
        </div>
        <div class="bg-surface-base border border-ink-primary/10 rounded-md p-8 transition-transform duration-200 hover:-translate-y-1">
          <span class="inline-block font-sans text-[0.8125rem] font-semibold tracking-[0.06em] text-brand-primary mb-4">02</span>
          <h3 class="font-sans text-[1.25rem] font-bold text-ink-primary m-0 mb-2 leading-[1.3]">{t['principles.2']}</h3>
          <p class="font-sans text-[0.9375rem] text-ink-muted leading-[1.6] m-0">{t['about.principles.2.text']}</p>
        </div>
        <div class="bg-surface-base border border-ink-primary/10 rounded-md p-8 transition-transform duration-200 hover:-translate-y-1">
          <span class="inline-block font-sans text-[0.8125rem] font-semibold tracking-[0.06em] text-brand-primary mb-4">03</span>
          <h3 class="font-sans text-[1.25rem] font-bold text-ink-primary m-0 mb-2 leading-[1.3]">{t['principles.3']}</h3>
          <p class="font-sans text-[0.9375rem] text-ink-muted leading-[1.6] m-0">{t['about.principles.3.text']}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CURFEE acronym -->
  <section class="py-20 sm:py-[104px] xl:py-[144px]" aria-labelledby="curfee-heading">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="max-w-[720px] mb-14">
        <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0">
          {t['about.curfee.eyebrow']}
        </p>
        <h2
          id="curfee-heading"
          class="font-sans text-[clamp(1.75rem,3vw,2.5rem)] font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 mt-4"
        >
          {t['about.curfee.heading']}
        </h2>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 lg:gap-x-12 lg:gap-y-12">
        {curfeeLetters.map((c) => (
          <div class="grid grid-cols-[56px_1fr] gap-5 items-start">
            <div
              class="w-12 h-12 rounded-xs bg-brand-primary text-brand-onPrimary flex items-center justify-center font-sans font-extrabold text-[1.25rem]"
              aria-hidden="true"
            >
              {c.letter}
            </div>
            <div>
              <h3 class="font-sans text-[1.125rem] font-bold text-ink-primary m-0 mb-2 leading-[1.3]">
                {c.word}
              </h3>
              <p class="font-sans text-[0.9375rem] text-ink-muted leading-[1.6] m-0 max-w-[40ch]">
                {c.text}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-[104px] xl:py-[144px] bg-brand-primary text-brand-onPrimary">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="max-w-[760px]">
        <h2 class="font-sans text-[clamp(1.75rem,3vw,2.5rem)] font-extrabold leading-[1.1] tracking-[-0.015em] text-balance break-words hyphens-auto m-0 text-brand-onPrimary">
          {t['calltoaction.heading']}
        </h2>
        <p class="font-sans text-[1.125rem] leading-[1.6] text-surface-base/85 max-w-[640px] font-medium mt-4">
          {t['calltoaction.subtitle']}
        </p>
        <a
          href={routes.contact}
          class="inline-flex items-center gap-2 mt-8 px-7 py-3.5 font-sans text-[0.9375rem] font-bold bg-surface-base text-brand-primary border-[1.5px] border-surface-base rounded-md no-underline transition-colors duration-200 hover:bg-surface-base/85"
        >
          {t['hero.cta']}
        </a>
      </div>
    </div>
  </section>

</article>
