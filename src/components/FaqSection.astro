---
import Icon from '@/components/shared/Icon.astro';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}

const { translations: t } = Astro.props;

const groups = [
  {
    label: t['faq.group.fit'],
    items: [
      { question: t['faq.1.question'], answer: t['faq.1.answer'] },
    ],
  },
  {
    label: t['faq.group.process'],
    items: [
      { question: t['faq.2.question'], answer: t['faq.2.answer'] },
      { question: t['faq.4.question'], answer: t['faq.4.answer'] },
      { question: t['faq.keep.question'], answer: t['faq.keep.answer'] },
    ],
  },
  {
    label: t['faq.group.work'],
    items: [
      { question: t['faq.patterns.structural.question'], answer: t['faq.patterns.structural.answer'] },
      { question: t['faq.patterns.operational.question'], answer: t['faq.patterns.operational.answer'] },
      { question: t['faq.decisions.question'], answer: t['faq.decisions.answer'] },
      { question: t['faq.enforcement.question'], answer: t['faq.enforcement.answer'] },
      { question: t['faq.ai.question'], answer: t['faq.ai.answer'] },
      { question: t['faq.cultural.question'], answer: t['faq.cultural.answer'] },
    ],
  },
  {
    label: t['faq.group.working'],
    items: [
      { question: t['faq.5.question'], answer: t['faq.5.answer'] },
      { question: t['faq.international.question'], answer: t['faq.international.answer'] },
      { question: t['faq.6.question'], answer: t['faq.6.answer'] },
    ],
  },
];

const answerProseClass = "text-body-medium md:text-body-large text-ink-muted leading-relaxed pb-6 [&_p]:mb-3 [&_p:last-child]:mb-0 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1.5 [&_ul]:mb-3 [&_ul:last-child]:mb-0 [&_li]:leading-relaxed [&_strong]:text-ink-primary [&_strong]:font-semibold";
---

<section id="faq" class="uc-section" aria-labelledby="faq-heading">
  <div class="uc-container">
    <div class="faq-inner">
      <p class="uc-eyebrow" style="margin-bottom: 16px;">FAQ</p>
      <h2 id="faq-heading" class="uc-h2">{t['faq.heading']}</h2>
      <p class="uc-lead" style="margin-top: 16px; color: rgb(var(--brand-primary)); font-weight: 600; max-width: 65ch;">{t['faq.subtitle']}</p>

      <div style="margin-top: 48px;">
        {groups.map((group, gi) => (
          <div class={gi > 0 ? 'faq-group faq-group--gap' : 'faq-group'}>
            <h3 class="faq-grouplabel">{group.label}</h3>
            <div class="faq-list">
              {group.items.map((q, i) => (
                <details class="group faq-details" name="faq-accordion">
                  <summary class="faq-summary">
                    <span>{q.question}</span>
                    <span class="faq-toggle" aria-hidden="true">
                      <Icon name="expand_less" class="w-5 h-5" />
                    </span>
                  </summary>
                  <div class="faq-content">
                    <div class="faq-content-inner">
                      <div
                        class={answerProseClass}
                        {...((gi === 0 && i === 0) || (gi === 2 && i <= 4) ? { 'data-speakable': true } : {})}
                        set:html={q.answer}
                      />
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-inner { max-width: 920px; }
  .faq-group--gap { margin-top: 40px; }
  .faq-grouplabel {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--brand-primary));
    margin: 0 0 16px 0;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-details {
    background: rgb(var(--surface-base));
    border: 1px solid rgb(var(--ink-primary) / 0.1);
    border-radius: 8px;
    transition: border-color 200ms ease;
  }
  .faq-details[open] {
    border-color: rgb(var(--brand-primary));
  }
  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    padding: 20px 24px;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: rgb(var(--ink-primary));
    list-style: none;
    transition: color 200ms ease;
  }
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-summary:hover {
    color: rgb(var(--brand-primary));
  }
  .faq-toggle {
    flex-shrink: 0;
    margin-left: 16px;
    color: rgb(var(--ink-primary) / 0.4);
    transition: transform 200ms ease;
  }
  .faq-details[open] .faq-toggle {
    transform: rotate(180deg);
  }
  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 150ms var(--ease-standard);
  }
  .faq-content-inner {
    overflow: hidden;
    padding: 0 24px;
  }
  .faq-details[open] > .faq-content {
    grid-template-rows: 1fr;
  }
  .faq-details[open] > .faq-content .faq-content-inner {
    padding-bottom: 20px;
  }
</style>

<script>
  function initFaqCloseOnClick() {
    const detailsList = document.querySelectorAll<HTMLDetailsElement>('.faq-details');

    // Close any open FAQ when clicking outside
    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      if (!target) return;
      if (target.closest('.faq-details')) return;
      detailsList.forEach((d) => { if (d.open) d.open = false; });
    });

    // Click anywhere inside an open FAQ (except links/buttons) closes it
    detailsList.forEach((d) => {
      const content = d.querySelector<HTMLElement>('.faq-content');
      if (!content) return;
      content.addEventListener('click', (event) => {
        const target = event.target as Element | null;
        if (target && target.closest('a, button')) return;
        d.open = false;
      });
    });
  }

  document.addEventListener('astro:page-load', initFaqCloseOnClick);
  initFaqCloseOnClick();
</script>
