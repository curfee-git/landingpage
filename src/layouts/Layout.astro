---
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/shared/Header.astro';
import Footer from '@/components/shared/Footer.astro';
import ScrollToTop from '@/components/shared/ScrollToTop.astro';
import { getTranslations } from '@/i18n/translations';
import { EXTERNAL } from '@/configurations/routes';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: object | object[];
  dateModified?: string;
  datePublished?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  showHeader?: boolean;
  ogImageOverride?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageType?: string;
  hasSpeakable?: boolean;
  articleSection?: string;
  articleTags?: string[];
  enableTransitions?: boolean;
}

const t = getTranslations();

const {
  title,
  description = t['meta.home.description'],
  canonicalPath = '',
  jsonLd,
  dateModified,
  datePublished,
  ogType = 'website',
  noindex = false,
  showHeader = true,
  ogImageOverride,
  ogImageWidth,
  ogImageHeight,
  ogImageType,
  hasSpeakable = false,
  articleSection,
  articleTags,
  enableTransitions = true,
} = Astro.props;

const defaultOgImageDims = !ogImageOverride;
const resolvedOgWidth = ogImageWidth ?? (defaultOgImageDims ? 1200 : undefined);
const resolvedOgHeight = ogImageHeight ?? (defaultOgImageDims ? 630 : undefined);
const resolvedOgType = ogImageType ?? (defaultOgImageDims ? 'image/png' : undefined);

const siteUrl = 'https://curfee.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImage = ogImageOverride
  ? (ogImageOverride.startsWith('http') ? ogImageOverride : `${siteUrl}${ogImageOverride}`)
  : `${siteUrl}/assets/og-image.png`;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/#founder`,
  "name": "Philipp Höllinger",
  "givenName": "Philipp",
  "familyName": "Höllinger",
  "jobTitle": t['meta.about.jobTitle'],
  "description": "Philipp Höllinger ist Strukturarchitekt mit Sitz in Salzburg, Österreich, und alleiniger Gründer der Curfee e.U. (gegründet 2026). Er berät zu struktureller Architektur über Software, Infrastruktur und organisatorische Strukturen hinweg sowie zu Ursachenanalyse und wendet das Prinzip der Entscheidungsdurchsetzung an: Architekturentscheidungen werden vom System selbst durchgesetzt – über Pipelines, automatisierte Checks und Tool-Konfiguration, statt durch Disziplin, Erinnerung oder Wachsamkeit einzelner Personen.",
  "url": siteUrl,
  "mainEntityOfPage": `${siteUrl}/#about`,
  "image": {
    "@type": "ImageObject",
    "url": `${siteUrl}/assets/profile.png`,
    "contentUrl": `${siteUrl}/assets/profile.png`,
    "caption": "Porträt von Philipp Höllinger, Gründer der Curfee",
    "width": 1024,
    "height": 1536
  },
  "sameAs": [EXTERNAL.linkedin],
  "nationality": { "@type": "Country", "name": "Österreich" },
  "knowsAbout": [
    "Strukturarchitektur",
    "Systemarchitektur",
    "Softwarearchitektur",
    "Infrastrukturarchitektur",
    "Organisationsarchitektur",
    "Systemanalyse",
    "IT-Beratung",
    "Ursachenanalyse",
    "Abhängigkeitsanalyse",
    "Entscheidungsdurchsetzung",
    "Prinzip der Entscheidungsdurchsetzung",
    "Standards- und Konventions-Design",
    "Tool-Landschaft-Bewertung",
    "Strukturberatung",
    "Change Management",
    "Qualitätssicherung",
    "Systementwicklung",
    "Onboarding",
    "Zusammenarbeit",
    "Wissenstransfer"
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Strukturarchitekt",
    "occupationLocation": { "@id": `${siteUrl}/#place-salzburg` },
    "occupationalCategory": {
      "@type": "CategoryCode",
      "codeValue": "15-1199.02",
      "name": "Computer Systems Engineer/Architect",
      "inCodeSet": {
        "@type": "CategoryCodeSet",
        "name": "O*NET-SOC"
      }
    },
    "skills": "Strukturarchitektur über Software, Infrastruktur und organisatorische Strukturen hinweg, Ursachenanalyse, Abhängigkeitsanalyse, Entscheidungsdurchsetzung, Standards- und Konventions-Design, Tool-Landschaft-Bewertung"
  },
  "knowsLanguage": [
    { "@type": "Language", "name": "Deutsch", "alternateName": "de" },
    { "@type": "Language", "name": "Englisch", "alternateName": "en" }
  ],
  "worksFor": { "@id": `${siteUrl}/#organization` },
  "memberOf": { "@id": `${siteUrl}/#organization` },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  }
};

const placeLd = {
  "@context": "https://schema.org",
  "@type": "Place",
  "@id": `${siteUrl}/#place-salzburg`,
  "name": "Salzburg, Österreich",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lieferinger Hauptstraße 49A",
    "postalCode": "5020",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.8066,
    "longitude": 13.0089
  }
};

const organizationLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "ProfessionalService", "LocalBusiness"],
  "@id": `${siteUrl}/#organization`,
  "name": "Curfee",
  "legalName": "Curfee e.U.",
  "alternateName": ["Curfee Strukturarchitektur-Beratung", "Curfee Beratung"],
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "@id": `${siteUrl}/#logo`,
    "url": `${siteUrl}/assets/og-image.png`,
    "width": 1200,
    "height": 630,
    "caption": "Curfee"
  },
  "image": { "@id": `${siteUrl}/#logo` },
  "description": t['meta.home.jsonld.description'],
  "slogan": t['footer.tagline'],
  "founder": { "@id": `${siteUrl}/#founder` },
  "employee": { "@id": `${siteUrl}/#founder` },
  "numberOfEmployees": { "@type": "QuantitativeValue", "value": 1 },
  "foundingDate": "2026",
  "foundingLocation": { "@id": `${siteUrl}/#place-salzburg` },
  "location": { "@id": `${siteUrl}/#place-salzburg` },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lieferinger Hauptstraße 49A",
    "postalCode": "5020",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.8066,
    "longitude": 13.0089
  },
  "areaServed": [
    { "@type": "Country", "name": "Österreich", "alternateName": "AT" },
    { "@type": "Country", "name": "Deutschland", "alternateName": "DE" },
    { "@type": "Country", "name": "Schweiz", "alternateName": "CH" }
  ],
  "serviceArea": {
    "@type": "AdministrativeArea",
    "name": "DACH-Region"
  },
  "knowsAbout": [
    "Strukturarchitektur",
    "Systemarchitektur",
    "Softwarearchitektur",
    "Infrastrukturarchitektur",
    "Organisationsarchitektur",
    "Systemanalyse",
    "IT-Beratung",
    "Ursachenanalyse",
    "Abhängigkeitsanalyse",
    "Prinzip der Entscheidungsdurchsetzung",
    "Standards- und Konventions-Design",
    "Tool-Landschaft-Bewertung",
    "Strukturberatung",
    "Auflösung technischer Schulden",
    "Change Management",
    "Qualitätssicherung",
    "Systementwicklung",
    "Onboarding",
    "Zusammenarbeit",
    "Wissenstransfer"
  ],
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "email": EXTERNAL.email,
      "telephone": EXTERNAL.tel.replace(/^tel:/, ''),
      "contactType": "Kundenservice",
      "availableLanguage": ["de", "en"],
      "areaServed": ["AT", "DE", "CH"]
    },
    {
      "@type": "ContactPoint",
      "email": EXTERNAL.email,
      "contactType": "Vertrieb",
      "availableLanguage": ["de", "en"]
    }
  ],
  "potentialAction": {
    "@type": "CommunicateAction",
    "name": "Per E-Mail kontaktieren",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": EXTERNAL.mailto,
      "inLanguage": ["de"]
    }
  },
  "knowsLanguage": [
    { "@type": "Language", "name": "Deutsch", "alternateName": "de" },
    { "@type": "Language", "name": "Englisch", "alternateName": "en" }
  ],
  "vatID": "ATU83146203",
  "taxID": "ATU83146203",
  "identifier": [
    { "@type": "PropertyValue", "propertyID": "VAT", "value": "ATU83146203" },
    { "@type": "PropertyValue", "propertyID": "GISA", "value": "39453891" }
  ],
  "memberOf": {
    "@type": "Organization",
    "name": "Wirtschaftskammer Österreich",
    "alternateName": "WKO",
    "url": "https://www.wko.at"
  },
  "keywords": [
    "Strukturarchitektur Beratung",
    "Strukturarchitektur Österreich",
    "Strukturarchitekt Österreich",
    "Organisationsstruktur Beratung",
    "Systemarchitektur Beratung",
    "Systemarchitektur Österreich",
    "Architekturentscheidungen durchsetzen",
    "Systemarchitekt Österreich",
    "Entscheidungsdurchsetzung",
    "Architektur-Governance-Automatisierung",
    "Ursachenanalyse",
    "Systemlandschaft-Bewertung",
    "Abhängigkeitsanalyse",
    "Standards-Durchsetzung Pipelines",
    "Strukturberatung",
    "IT-Beratung Österreich"
  ],
  "sameAs": [
    EXTERNAL.linkedin
  ]
};

const webSiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "name": "Curfee",
  "alternateName": "Curfee: Structural Architecture Consulting",
  "url": siteUrl,
  "inLanguage": "de",
  "publisher": { "@id": `${siteUrl}/#organization` },
  "about": { "@id": `${siteUrl}/#organization` },
  "mainEntity": { "@id": `${siteUrl}/#organization` }
};

const speakableLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}${canonicalPath}#webpage`,
  "name": title,
  "url": canonicalUrl,
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#organization` },
  "author": { "@id": `${siteUrl}/#founder` },
  "publisher": { "@id": `${siteUrl}/#organization` },
  "inLanguage": "de",
  ...(dateModified && { "dateModified": dateModified }),
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": ogImage
  },
  ...(hasSpeakable && {
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["[data-speakable]"]
    }
  })
};
---

<!doctype html>
<html lang="de-AT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <meta name="color-scheme" content="light dark" />

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=(), payment=(), usb=(), browsing-topics=(), interest-cohort=(), fullscreen=(self), autoplay=()" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' data:; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.web3forms.com; frame-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Philipp Höllinger" />
    <meta name="publisher" content="Curfee e.U." />
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="googlebot" content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="bingbot" content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    {datePublished && <meta property="article:published_time" content={datePublished} />}
    {dateModified && <meta property="article:modified_time" content={dateModified} />}
    {ogType === 'article' && <meta property="article:author" content="Philipp Höllinger" />}
    {ogType === 'article' && <meta property="article:publisher" content="https://curfee.com" />}
    {ogType === 'article' && articleSection && <meta property="article:section" content={articleSection} />}
    {ogType === 'article' && articleTags && articleTags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Geo Meta Tags: Local SEO (Salzburg, Austria) -->
    <meta name="geo.region" content="AT-5" />
    <meta name="geo.placename" content="Salzburg, Österreich" />
    <meta name="geo.position" content="47.8066;13.0089" />
    <meta name="ICBM" content="47.8066, 13.0089" />

    <!-- Preload critical fonts (only above-the-fold fonts) -->
    <link rel="preload" href="/assets/fonts/inter/inter.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/inter-tight/inter-tight-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- LLM context files -->
    <link rel="help" type="text/plain" href={`${siteUrl}/llms.txt`} title="LLM context" />
    <link rel="help" type="text/plain" href={`${siteUrl}/llms-full.txt`} title="LLM full context" />

    <!-- Canonical URL -->
    {!noindex && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Curfee" />
    <meta property="og:locale" content="de_AT" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    {resolvedOgType && <meta property="og:image:type" content={resolvedOgType} />}
    {resolvedOgWidth && <meta property="og:image:width" content={String(resolvedOgWidth)} />}
    {resolvedOgHeight && <meta property="og:image:height" content={String(resolvedOgHeight)} />}
    <meta property="og:image:alt" content={t['meta.og.image.alt']} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={t['meta.og.image.alt']} />

    <!-- Favicons -->
    <link rel="icon" href="/assets/favicons/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/assets/favicons/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/assets/favicons/favicon_32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/assets/favicons/favicon_16x16.png" type="image/png" sizes="16x16" />
    <link rel="icon" href="/assets/favicons/android_chrome_192x192.png" type="image/png" sizes="192x192" />
    <link rel="icon" href="/assets/favicons/android_chrome_512x512.png" type="image/png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/assets/favicons/apple_touch_icon.png" sizes="180x180" />
    <link rel="manifest" href="/assets/favicons/site.webmanifest" />
    <meta name="theme-color" content="#003366" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141416" media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content="#003366" />
    <meta name="msapplication-TileImage" content="/assets/favicons/android_chrome_192x192.png" />

    <!-- Identity verification -->
    <link rel="me" href={EXTERNAL.linkedin} />

    <!-- Sitemap + RSS -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Curfee Blog" href="/rss.xml" />

    {!noindex && (
      <>
        <!-- Structured Data: Sitewide WebSite + Place + Person + Organization + WebPage -->
        <script is:inline type="application/ld+json" set:html={JSON.stringify(webSiteLd)} />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(placeLd)} />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(speakableLd)} />
        <!-- Structured Data: Page-specific -->
        {jsonLd && (
          Array.isArray(jsonLd)
            ? jsonLd.map((ld) => (
                <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
              ))
            : <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
        )}
      </>
    )}

    {enableTransitions && <ClientRouter />}
  </head>
  <body>
    {showHeader && <Header />}
    <main {...(enableTransitions ? { 'transition:animate': 'fade' } : {})}>
      <slot />
    </main>
    <Footer {...(enableTransitions ? { 'transition:persist': true } : {})} />
    <ScrollToTop />
  </body>
</html>
