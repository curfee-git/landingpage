---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { getRoutes } from '@/configurations/routes';
import { getTranslations } from '@/i18n/translations';
import { postSlug, formatDate, extractToc, extractReferences, reorderForGrid } from '@/content/_posts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const t = getTranslations();
const routes = getRoutes();
const { Content } = await render(post);
const slug = postSlug(post);
const canonicalPath = `${routes.blog}${slug}/`;
const toc = extractToc(post.body ?? '');
const references = reorderForGrid(extractReferences(post.body ?? ''), (ref) => ref.title.length + ref.url.length);
const tocRows = Math.max(1, Math.ceil(toc.length / 2));
const referencesRows = Math.max(1, Math.ceil(references.length / 2));

const postImage = post.data.coverImage
  ? (post.data.coverImage.startsWith('http') ? post.data.coverImage : `https://curfee.com${post.data.coverImage}`)
  : 'https://curfee.com/assets/og-image.png';
const usingCoverImage = Boolean(post.data.coverImage);

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
    { "@type": "ListItem", "position": 2, "name": t['blog.indexHeading'], "item": "https://curfee.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://curfee.com${canonicalPath}` }
  ]
};

const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `https://curfee.com${canonicalPath}#post`,
  "headline": post.data.title,
  "description": post.data.excerpt,
  "image": usingCoverImage
    ? postImage
    : {
        "@type": "ImageObject",
        "url": postImage,
        "width": 1200,
        "height": 630
      },
  "datePublished": post.data.createdAt.toISOString(),
  "dateModified": (post.data.updatedAt ?? post.data.createdAt).toISOString(),
  "author": { "@id": "https://curfee.com/#founder" },
  "publisher": { "@id": "https://curfee.com/#organization" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://curfee.com${canonicalPath}` },
  "inLanguage": "en",
  "url": `https://curfee.com${canonicalPath}`,
  "keywords": [post.data.topic, ...post.data.tags].join(', '),
  "wordCount": (post.body ?? '').split(/\s+/).filter(Boolean).length,
  "isPartOf": { "@id": "https://curfee.com/blog/#blog" },
};

const jsonLd = [blogPostingLd, breadcrumbLd];
---

<Layout
  title={`${post.data.title} | Curfee Blog`}
  description={post.data.excerpt}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  ogType="article"
  datePublished={post.data.createdAt.toISOString().slice(0, 10)}
  dateModified={(post.data.updatedAt ?? post.data.createdAt).toISOString().slice(0, 10)}
  ogImageOverride={usingCoverImage ? post.data.coverImage : undefined}
  ogImageType={usingCoverImage ? undefined : 'image/png'}
  ogImageWidth={usingCoverImage ? undefined : 1200}
  ogImageHeight={usingCoverImage ? undefined : 630}
  articleSection={post.data.topic}
  articleTags={post.data.tags}
>
  <article class="py-20 sm:py-[104px] xl:py-[144px]">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="max-w-[880px] mx-auto">

        <a href={routes.blog} class="post-back inline-block font-sans text-[0.875rem] text-brand-primary no-underline mb-8 border-b border-transparent font-semibold transition-colors duration-200 hover:border-brand-primary">← {t['blog.backToIndex']}</a>

        <header class="mb-14">
          <div class="flex flex-wrap items-center gap-3 mb-6 font-sans text-[0.8125rem] text-ink-muted">
            <span class="font-sans text-[0.8125rem] font-semibold tracking-[0.06em] uppercase text-brand-primary">{post.data.topic}</span>
            <span class="text-ink-muted">
              <time datetime={post.data.createdAt.toISOString()}>{formatDate(post.data.createdAt)}</time>
              {post.data.updatedAt && post.data.updatedAt.toISOString() !== post.data.createdAt.toISOString() && (
                <>
                  <span aria-hidden="true"> · </span>
                  <span class="text-ink-muted">
                    {t['blog.updatedLabel']} <time datetime={post.data.updatedAt.toISOString()}>{formatDate(post.data.updatedAt)}</time>
                  </span>
                </>
              )}
            </span>
          </div>
          <h1 class="font-sans text-[clamp(2.5rem,5vw,4rem)] font-extrabold leading-[1.05] tracking-[-0.02em] text-balance break-words hyphens-auto m-0">
            {post.data.title}
          </h1>
          <p class="font-sans text-[1.125rem] text-ink-muted leading-[1.65] mt-6 m-0 max-w-[65ch]">
            {post.data.excerpt}
          </p>
        </header>

        {toc.length > 0 && (
          <nav class="bg-surface-soft border border-ink-primary/10 rounded-md py-6 px-7 mb-14" aria-labelledby="toc-heading">
            <h2 id="toc-heading" class="font-sans text-[0.8125rem] font-semibold tracking-[0.06em] uppercase text-brand-primary m-0 mb-4">
              {t['blog.tocHeading']}
            </h2>
            <ol class="post-toc-list flex flex-col gap-2.5 list-none p-0 m-0 md:grid md:grid-cols-2 md:grid-flow-col md:gap-x-8 md:gap-y-2.5" style={`grid-template-rows: repeat(${tocRows}, auto);`}>
              {toc.map((item, i) => (
                <li class="flex items-baseline gap-3">
                  <span class="font-sans text-[0.75rem] font-bold text-brand-primary w-6 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                  <a href={`#${item.slug}`} class="font-sans text-[0.9375rem] text-ink-primary no-underline leading-[1.4] border-b border-transparent transition-colors duration-200 hover:border-brand-primary">
                    {item.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )}

        {post.data.coverImage && (
          <figure class="-mx-6 mb-12 md:mx-0">
            <img
              class="w-full h-auto rounded-none md:rounded-lg"
              src={post.data.coverImage}
              alt={post.data.coverImageAlt ?? ''}
              loading="lazy"
              decoding="async"
              width={post.data.coverImageWidth}
              height={post.data.coverImageHeight}
            />
            {post.data.coverImageAlt && (
              <figcaption class="text-[0.75rem] text-ink-muted mt-3 mx-6 md:mx-0">
                {post.data.coverImageAlt}
              </figcaption>
            )}
          </figure>
        )}

        <div class={`prose-blog post-content text-body-large text-ink-primary leading-[1.7] [&_h2]:text-headline-small [&_h2]:font-extrabold [&_h2]:text-ink-primary [&_h2]:mt-14 [&_h2]:mb-4 [&_h2]:scroll-mt-20 [&_h2]:md:scroll-mt-24 [&_h3]:font-sans [&_h3]:font-bold [&_h3]:text-[1.25rem] [&_h3]:leading-[1.3] [&_h3]:text-ink-primary [&_h3]:mt-10 [&_h3]:mb-3 [&_h3]:scroll-mt-20 [&_h3]:md:scroll-mt-24 [&_p]:mb-6 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-6 [&_ul]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-6 [&_ol]:space-y-2 [&_li]:leading-[1.7] [&_a]:text-brand-primary [&_a]:no-underline [&_a]:border-b [&_a]:border-brand-primary [&_a:hover]:opacity-85 [&_strong]:font-bold [&_strong]:text-ink-primary [&_blockquote]:border-l-2 [&_blockquote]:border-brand-primary [&_blockquote]:pl-6 [&_blockquote]:my-10 [&_blockquote]:font-medium [&_blockquote]:text-title-medium [&_blockquote]:text-ink-primary [&_blockquote]:leading-[1.6] [&_blockquote_p]:mb-0 [&_code]:bg-surface-soft [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded-xs [&_code]:text-body-medium [&_pre]:bg-surface-soft [&_pre]:border [&_pre]:border-stroke-subtle [&_pre]:rounded-xs [&_pre]:p-4 [&_pre]:my-6 [&_pre]:overflow-x-auto [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_hr]:border-stroke-subtle [&_hr]:my-12`}>
          <Content />
        </div>

        {references.length > 0 && (
          <section class="mt-16 py-7 px-8 bg-surface-soft border border-ink-primary/10 rounded-md" aria-labelledby="references-heading">
            <h2 id="references-heading" class="font-sans text-[0.8125rem] font-semibold tracking-[0.06em] uppercase text-brand-primary m-0 mb-4">
              {t['blog.referencesHeading']}
            </h2>
            <ol class="post-references-list flex flex-col gap-3.5 list-none p-0 m-0 md:grid md:grid-cols-2 md:grid-flow-col md:gap-x-8 md:gap-y-3.5" style={`grid-template-rows: repeat(${referencesRows}, auto);`}>
              {references.map((ref, i) => (
                <li class="flex items-baseline gap-3">
                  <span class="font-sans text-[0.75rem] font-medium text-ink-muted w-6 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                  <span class="flex-1 min-w-0">
                    <a
                      href={ref.url}
                      rel="noopener"
                      target="_blank"
                      class="block font-sans text-[0.9375rem] font-semibold text-ink-primary no-underline border-b border-transparent transition-colors duration-200 hover:text-brand-primary hover:border-brand-primary"
                    >
                      {ref.title}
                    </a>
                    <span class="block font-sans text-[0.75rem] text-ink-muted mt-1 break-all">
                      {ref.url}
                    </span>
                  </span>
                </li>
              ))}
            </ol>
          </section>
        )}

        <aside class="mt-16 py-9 px-10 bg-surface-soft border border-ink-primary/10 rounded-md" aria-labelledby="cta-heading">
          <h2 id="cta-heading" class="font-sans text-2xl font-extrabold text-ink-primary m-0 mb-2 leading-[1.2] tracking-[-0.01em]">
            {t['blog.ctaTitle']}
          </h2>
          <p class="font-sans text-ink-muted leading-[1.6] m-0 mb-5 max-w-[65ch]">
            {t['blog.ctaText']}
          </p>
          <a
            href={routes.contact}
            class="inline-flex items-center font-sans text-[0.9375rem] font-bold text-brand-primary no-underline border-b border-brand-primary transition-opacity duration-200 hover:opacity-85"
          >
            {t['blog.ctaLink']}
          </a>
        </aside>

      </div>
    </div>
  </article>
</Layout>

