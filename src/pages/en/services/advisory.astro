---
import Layout from '@/layouts/Layout.astro';
import ServiceDetail from '@/components/ServiceDetail.astro';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations(Astro.currentLocale);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: t['services.advisory.title'],
  description: t['services.advisory.problem'],
  provider: { '@type': 'Organization', name: 'Curfee' },
  areaServed: 'DACH',
};

const timeline = [
  {
    phase: t['services.advisory.timeline.1.phase'],
    title: t['services.advisory.timeline.1.title'],
    outcome: t['services.advisory.timeline.1.outcome'],
    items: [t['services.advisory.timeline.1.item.1'], t['services.advisory.timeline.1.item.2'], t['services.advisory.timeline.1.item.3']],
  },
  {
    phase: t['services.advisory.timeline.2.phase'],
    title: t['services.advisory.timeline.2.title'],
    outcome: t['services.advisory.timeline.2.outcome'],
    items: [t['services.advisory.timeline.2.item.1'], t['services.advisory.timeline.2.item.2'], t['services.advisory.timeline.2.item.3']],
  },
  {
    phase: t['services.advisory.timeline.3.phase'],
    title: t['services.advisory.timeline.3.title'],
    outcome: t['services.advisory.timeline.3.outcome'],
    items: [t['services.advisory.timeline.3.item.1'], t['services.advisory.timeline.3.item.2'], t['services.advisory.timeline.3.item.3']],
  },
];
---

<Layout
  title={`${t['services.advisory.title']} — Curfee`}
  description={t['services.advisory.problem']}
  canonicalPath={Astro.url.pathname}
  jsonLd={jsonLd}
>
  <ServiceDetail
    serviceKey="advisory"
    icon="handshake"
    title={t['services.advisory.title']}
    subtitle={t['services.advisory.subtitle']}
    duration={t['services.advisory.duration']}
    problem={t['services.advisory.problem']}
    forwhom={[t['services.advisory.forwhom.1'], t['services.advisory.forwhom.2'], t['services.advisory.forwhom.3']]}
    timeline={timeline}
    delivers={[t['services.advisory.delivers.1'], t['services.advisory.delivers.2'], t['services.advisory.delivers.3'], t['services.advisory.delivers.4']]}
    excludes={[t['services.advisory.excludes.1'], t['services.advisory.excludes.2'], t['services.advisory.excludes.3']]}
    objectionQ={t['services.advisory.objection.q']}
    objectionA={t['services.advisory.objection.a']}
    cta={t['services.advisory.cta']}
    translations={t}
    accent="tertiary"
  />
</Layout>
