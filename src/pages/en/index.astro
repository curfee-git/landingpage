---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ObservationsSection from '@/components/ObservationsSection.astro';
import ServicesSection from '@/components/ServicesSection.astro';
// import CaseStudySection from '@/components/CaseStudySection.astro'; // disabled — component kept for future
import AboutSection from '@/components/AboutSection.astro';
import FaqSection from '@/components/FaqSection.astro';
import ContactSection from '@/components/ContactSection.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'en' as const;
const t = getTranslations(lang);

const faqEntries = [
  {
    id: "https://curfee.com/en/#faq-dep",
    name: t['faq.dep.question'],
    text: t['faq.dep.answer'],
  },
  ...([1, 2, 4, 5, 6] as const).map((n) => ({
    id: `https://curfee.com/en/#faq-${n}`,
    name: t[`faq.${n}.question` as keyof typeof t],
    text: t[`faq.${n}.answer` as keyof typeof t],
  })),
];
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://curfee.com/en/#faq",
  "inLanguage": "en",
  "about": { "@id": "https://curfee.com/#organization" },
  "author": { "@id": "https://curfee.com/#founder" },
  "publisher": { "@id": "https://curfee.com/#organization" },
  "dateModified": "2026-04-13",
  "mainEntity": faqEntries.map((q) => ({
    "@type": "Question",
    "@id": q.id,
    "name": q.name,
    "author": { "@id": "https://curfee.com/#founder" },
    "acceptedAnswer": {
      "@type": "Answer",
      "author": { "@id": "https://curfee.com/#founder" },
      "text": q.text
    }
  }))
};

const aboutPageLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": "https://curfee.com/en/#about",
  "url": "https://curfee.com/en/#about",
  "mainEntity": { "@id": "https://curfee.com/#founder" },
  "isPartOf": { "@id": "https://curfee.com/#website" },
  "inLanguage": "en"
};

const jsonLd = [faqLd, aboutPageLd];
---

<Layout
  title={t['meta.home.title']}
  description={t['meta.home.description']}
  canonicalPath="/en/"
  jsonLd={jsonLd}
  lang={lang}
  dateModified="2026-04-13"
>
  <HeroSection translations={t} />
  <ObservationsSection translations={t} />
  <ServicesSection translations={t} />
  <AboutSection translations={t} />
  <FaqSection translations={t} />
  <ContactSection translations={t} />
</Layout>
