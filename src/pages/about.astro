---
import Layout from '@/layouts/Layout.astro';
import AboutSection from '@/components/AboutSection.astro';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://curfee.com/about/#about',
  url: 'https://curfee.com/about/',
  mainEntity: { '@id': 'https://curfee.com/#founder' },
  isPartOf: { '@id': 'https://curfee.com/#website' },
  inLanguage: 'en',
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t['breadcrumb.home'] ?? 'Home', item: 'https://curfee.com/' },
    { '@type': 'ListItem', position: 2, name: t['about.heading'], item: 'https://curfee.com/about/' },
  ],
};
---

<Layout
  title={`${t['about.heading']} — Curfee`}
  description={t['about.who.1']}
  canonicalPath={Astro.url.pathname}
  jsonLd={[jsonLd, breadcrumbLd]}
>
  <AboutSection translations={t} />
</Layout>
