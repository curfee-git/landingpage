---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/HeroSection.astro';
import VisionSection from '@/components/VisionSection.astro';
import ProcessSection from '@/components/ProcessSection.astro';
import ServicesSection from '@/components/ServicesSection.astro';
import CaseStudySection from '@/components/CaseStudySection.astro';
import AboutSection from '@/components/AboutSection.astro';
import ContactSection from '@/components/ContactSection.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'de' as const;
const t = getTranslations(lang);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Curfee",
  "url": "https://curfee.com",
  "description": "Struktur in Systemen etablieren, die Bestand hat. Diagnose, Begleitung, Sparring.",
  "inLanguage": ["en", "de"],
  "publisher": { "@id": "https://curfee.com/#organization" }
};
---

<Layout
  title="Curfee — Struktur, die Bestand hat · Diagnose, Begleitung, Sparring"
  description="Philipp Höllinger, Softwarearchitekt aus Salzburg. Ich begleite Organisationen dabei, Struktur in ihren Systemen zu etablieren, die Bestand hat. Diagnose, Begleitung, Sparring."
  canonicalPath="/de/"
  jsonLd={jsonLd}
  lang={lang}
  dateModified="2026-03-30"
>
  <HeroSection translations={t} />
  <VisionSection translations={t} />
  <ProcessSection translations={t} />
  <ServicesSection translations={t} />
  <CaseStudySection translations={t} />
  <AboutSection translations={t} />
  <ContactSection translations={t} />
</Layout>
