---
import Layout from '@/layouts/Layout.astro';
import { EXTERNAL } from '@/configurations/routes';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
    { "@type": "ListItem", "position": 2, "name": t['footer.legal.privacy'], "item": "https://curfee.com/privacy/" }
  ]
};
---

<Layout
  title={t['meta.privacy.title']}
  description={t['meta.privacy.description']}
  canonicalPath={Astro.url.pathname}
  jsonLd={jsonLd}
  dateModified="2026-04-27"
>
  <article class="py-20 sm:py-[104px] xl:py-[144px]">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="max-w-[920px] mx-auto">

        <header class="mb-16">
          <p class="font-sans text-[0.8125rem] font-extrabold tracking-[0.06em] uppercase text-brand-primary m-0">
            {t['legal.eyebrow']}
          </p>
          <h1 class="font-sans text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.02em] text-balance break-words hyphens-auto m-0 mt-4">
            {t['privacy.heading']}
          </h1>
          <p class="text-body-x-large text-ink-muted mt-6 m-0 max-w-[65ch]">
            {t['privacy.scope']}
          </p>
        </header>

        <div class="flex flex-col gap-14">

          <section class="grid grid-cols-1 gap-5 md:grid-cols-2">
            <div class="bg-surface-base border border-ink-primary/10 rounded-md p-7">
              <h2 class="font-sans text-[0.6875rem] font-semibold tracking-[0.14em] uppercase text-ink-muted m-0 mb-4">
                {t['privacy.controller.heading']}
              </h2>
              <div class="flex flex-col gap-3.5 text-ink-primary font-sans text-[0.9375rem] leading-[1.5]">
                <p class="m-0 text-ink-primary font-medium">{t['imprint.company']}</p>
                <p class="m-0">{t['imprint.name']}</p>
                <div class="text-ink-muted">
                  <p class="m-0">{t['imprint.address.street']}</p>
                  <p class="m-0">{t['imprint.address.city']}</p>
                  <p class="m-0">{t['imprint.address.country']}</p>
                </div>
              </div>
            </div>

            <div class="bg-surface-base border border-ink-primary/10 rounded-md p-7">
              <h2 class="font-sans text-[0.6875rem] font-semibold tracking-[0.14em] uppercase text-ink-muted m-0 mb-4">
                {t['imprint.contact']}
              </h2>
              <div class="flex flex-col gap-3.5 text-ink-primary font-sans text-[0.9375rem] leading-[1.5]">
                <div>
                  <p class="font-sans text-[0.6875rem] font-semibold tracking-[0.14em] uppercase text-ink-muted m-0 mb-1.5">
                    {t['imprint.email.label']}
                  </p>
                  <p class="m-0">
                    <a href={EXTERNAL.mailto} class="text-brand-primary no-underline">
                      {EXTERNAL.email}
                    </a>
                  </p>
                </div>
                <div>
                  <p class="font-sans text-[0.6875rem] font-semibold tracking-[0.14em] uppercase text-ink-muted m-0 mb-1.5">
                    {t['privacy.phone.label']}
                  </p>
                  <p class="m-0">
                    <a href={EXTERNAL.tel} class="text-brand-primary no-underline">
                      {EXTERNAL.phone}
                    </a>
                  </p>
                </div>
              </div>
            </div>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.personal.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch]">{t['privacy.personal']}</p>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.rights.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch]">{t['privacy.rights']}</p>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.withdrawal.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch]">
              {t['privacy.withdrawal']}
              <a href={EXTERNAL.mailto} class="text-brand-primary no-underline">
                {EXTERNAL.email}
              </a>
            </p>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.complaint.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch]">{t['privacy.complaint']}</p>
            <div class="mt-5 bg-surface-base border border-ink-primary/10 rounded-md p-7">
              <div class="flex flex-col gap-3.5 text-ink-primary font-sans text-[0.9375rem] leading-[1.5]">
                <p class="m-0 text-ink-primary font-medium">{t['privacy.complaint.authority']}</p>
                <div class="text-ink-muted">
                  <p class="m-0">{t['privacy.complaint.address.street']}</p>
                  <p class="m-0">{t['privacy.complaint.address.city']}</p>
                  <p class="m-0">{t['privacy.complaint.address.country']}</p>
                </div>
                <div class="flex flex-col gap-1 text-ink-muted">
                  <p class="m-0">
                    {t['privacy.phone.label']}:
                    <a href={`tel:${t['privacy.complaint.phone'].replace(/\s/g, '')}`} class="text-brand-primary no-underline">
                      {t['privacy.complaint.phone']}
                    </a>
                  </p>
                  <p class="m-0">
                    {t['imprint.email.label']}:
                    <a href={`mailto:${t['privacy.complaint.email']}`} class="text-brand-primary no-underline">
                      {t['privacy.complaint.email']}
                    </a>
                  </p>
                  <p class="m-0">
                    {t['privacy.website.label']}
                    <a href={`https://${t['privacy.complaint.website']}`} target="_blank" rel="noopener noreferrer" class="text-brand-primary no-underline">
                      {t['privacy.complaint.website']}
                    </a>
                  </p>
                </div>
              </div>
            </div>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.ssl.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch]">{t['privacy.ssl']}</p>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.cookies.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch]">{t['privacy.cookies']}</p>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.links.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch]">{t['privacy.links']}</p>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.hosting.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch]">{t['privacy.hosting']}</p>
          </section>

          <section>
            <h2 class="font-sans text-xl md:text-2xl font-bold leading-[1.25] tracking-[-0.005em] m-0 mb-5">
              {t['privacy.web3forms.heading']}
            </h2>
            <p class="text-body-large text-ink-muted m-0 max-w-[65ch] [&>a]:text-brand-primary" set:html={t['privacy.web3forms.body']}></p>
          </section>

        </div>
      </div>
    </div>
  </article>
</Layout>
