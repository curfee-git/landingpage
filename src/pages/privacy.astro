---
import Layout from '@/layouts/Layout.astro';
import { EXTERNAL } from '@/configurations/routes';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
    { "@type": "ListItem", "position": 2, "name": t['footer.legal.privacy'], "item": "https://curfee.com/privacy/" }
  ]
};
---

<Layout
  title={t['meta.privacy.title']}
  description={t['meta.privacy.description']}
  canonicalPath={Astro.url.pathname}
  jsonLd={jsonLd}
  dateModified="2026-04-27"
>
  <article class="cf-section">
    <div class="cf-container">
      <div class="legal-page">

        <header class="legal-header">
          <p class="cf-eyebrow">{t['legal.eyebrow']}</p>
          <h1 class="cf-h1">{t['privacy.heading']}</h1>
          <p class="legal-subheading">{t['privacy.scope']}</p>
        </header>

        <div class="legal-content">

          <section class="legal-grid">
            <div class="legal-card">
              <h2 class="legal-card-title">{t['privacy.controller.heading']}</h2>
              <div class="legal-card-body">
                <p class="legal-emphasis">{t['imprint.company']}</p>
                <p>{t['imprint.name']}</p>
                <div class="legal-address">
                  <p>{t['imprint.address.street']}</p>
                  <p>{t['imprint.address.city']}</p>
                  <p>{t['imprint.address.country']}</p>
                </div>
              </div>
            </div>

            <div class="legal-card">
              <h2 class="legal-card-title">{t['imprint.contact']}</h2>
              <div class="legal-card-body">
                <div>
                  <p class="legal-label">{t['imprint.email.label']}</p>
                  <p><a href={EXTERNAL.mailto} class="legal-link">{EXTERNAL.email}</a></p>
                </div>
                <div>
                  <p class="legal-label">{t['privacy.phone.label']}</p>
                  <p><a href={EXTERNAL.tel} class="legal-link">{EXTERNAL.phone}</a></p>
                </div>
              </div>
            </div>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.personal.heading']}</h2>
            <p class="legal-prose">{t['privacy.personal']}</p>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.rights.heading']}</h2>
            <p class="legal-prose">{t['privacy.rights']}</p>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.withdrawal.heading']}</h2>
            <p class="legal-prose">{t['privacy.withdrawal']} <a href={EXTERNAL.mailto} class="legal-link">{EXTERNAL.email}</a></p>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.complaint.heading']}</h2>
            <p class="legal-prose">{t['privacy.complaint']}</p>
            <div class="legal-card legal-card--inline">
              <div class="legal-card-body">
                <p class="legal-emphasis">{t['privacy.complaint.authority']}</p>
                <div class="legal-address">
                  <p>{t['privacy.complaint.address.street']}</p>
                  <p>{t['privacy.complaint.address.city']}</p>
                  <p>{t['privacy.complaint.address.country']}</p>
                </div>
                <div class="legal-card-rows">
                  <p>{t['privacy.phone.label']}: <a href={`tel:${t['privacy.complaint.phone'].replace(/\s/g, '')}`} class="legal-link">{t['privacy.complaint.phone']}</a></p>
                  <p>{t['imprint.email.label']}: <a href={`mailto:${t['privacy.complaint.email']}`} class="legal-link">{t['privacy.complaint.email']}</a></p>
                  <p>Website: <a href={`https://${t['privacy.complaint.website']}`} target="_blank" rel="noopener noreferrer" class="legal-link">{t['privacy.complaint.website']}</a></p>
                </div>
              </div>
            </div>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.ssl.heading']}</h2>
            <p class="legal-prose">{t['privacy.ssl']}</p>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.cookies.heading']}</h2>
            <p class="legal-prose">{t['privacy.cookies']}</p>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.links.heading']}</h2>
            <p class="legal-prose">{t['privacy.links']}</p>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.hosting.heading']}</h2>
            <p class="legal-prose">{t['privacy.hosting']}</p>
          </section>

          <section>
            <h2 class="cf-h3 legal-section-heading">{t['privacy.web3forms.heading']}</h2>
            <p class="legal-prose [&>a]:text-brand-primary [&>a:hover]:underline" set:html={t['privacy.web3forms.body']}></p>
          </section>

        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .legal-page {
    max-width: 880px;
    margin: 0 auto;
  }
  .legal-header {
    margin-bottom: 64px;
  }
  .legal-header .cf-h1 {
    margin-top: 16px;
  }
  .legal-subheading {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: rgb(var(--ink-muted));
    line-height: 1.6;
    margin: 24px 0 0 0;
    max-width: 65ch;
  }

  .legal-content {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .legal-section-heading {
    margin: 0 0 20px 0;
  }

  .legal-prose {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: rgb(var(--ink-muted));
    line-height: 1.65;
    margin: 0 0 12px 0;
    max-width: 65ch;
  }
  .legal-prose:last-child {
    margin-bottom: 0;
  }
  .legal-emphasis {
    color: rgb(var(--ink-primary));
    font-weight: 500;
    margin: 0;
  }

  .legal-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .legal-card {
    background: rgb(var(--surface-base));
    border: 1px solid rgb(var(--ink-primary) / 0.1);
    border-radius: 8px;
    padding: 28px;
  }
  .legal-card--inline {
    margin-top: 20px;
  }
  .legal-card-title {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--ink-muted));
    margin: 0 0 16px 0;
  }
  .legal-card-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: rgb(var(--ink-primary));
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  .legal-card-body p {
    margin: 0;
  }
  .legal-card-rows {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: rgb(var(--ink-muted));
  }
  .legal-address {
    color: rgb(var(--ink-muted));
  }

  .legal-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--ink-muted));
    margin: 0 0 6px 0;
  }

  .legal-link {
    color: rgb(var(--brand-primary));
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease;
  }
  .legal-link:hover {
    border-bottom-color: rgb(var(--brand-primary));
  }

  @media (min-width: 701px) {
    .legal-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
