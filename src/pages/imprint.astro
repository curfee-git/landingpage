---
import Layout from '@/layouts/Layout.astro';
import { EXTERNAL } from '@/configurations/routes';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
    { "@type": "ListItem", "position": 2, "name": t['footer.legal.notice'], "item": "https://curfee.com/imprint/" }
  ]
};
---

<Layout
  title={t['meta.imprint.title']}
  description={t['meta.imprint.description']}
  canonicalPath={Astro.url.pathname}
  jsonLd={jsonLd}
  dateModified="2026-03-30"
>
  <article class="uc-section">
    <div class="uc-container">
      <div class="legal-page">

        <header class="legal-header">
          <p class="uc-eyebrow">{t['legal.eyebrow']}</p>
          <h1 class="uc-h1">{t['imprint.heading']}</h1>
          <p class="legal-subheading">{t['imprint.legal.basis']}</p>
        </header>

        <div class="legal-content">

          <section class="legal-grid">
            <div class="legal-card">
              <h2 class="legal-card-title">{t['imprint.owner']}</h2>
              <div class="legal-card-body">
                <p class="legal-emphasis">{t['imprint.company']}</p>
                <p>{t['imprint.name']}</p>
                <div class="legal-address">
                  <p>{t['imprint.address.street']}</p>
                  <p>{t['imprint.address.city']}</p>
                  <p>{t['imprint.address.country']}</p>
                </div>
              </div>
            </div>

            <div class="legal-card">
              <h2 class="legal-card-title">{t['imprint.contact']}</h2>
              <div class="legal-card-body">
                <div>
                  <p class="legal-label">{t['imprint.email.label']}</p>
                  <p><a href={EXTERNAL.mailto} class="legal-link">{EXTERNAL.email}</a></p>
                </div>
                <div>
                  <p class="legal-label">{t['imprint.phone.label']}</p>
                  <p><a href={EXTERNAL.tel} class="legal-link">{EXTERNAL.phone}</a></p>
                </div>
              </div>
            </div>
          </section>

          <section>
            <h2 class="uc-h3 legal-section-heading">{t['imprint.legal.heading']}</h2>
            <div class="legal-data-grid">
              <div>
                <p class="legal-label">{t['imprint.trade.label']}</p>
                <p class="legal-value">{t['imprint.trade']}</p>
              </div>
              <div>
                <p class="legal-label">{t['imprint.form.label']}</p>
                <p class="legal-value">{t['imprint.form']}</p>
              </div>
              <div>
                <p class="legal-label">{t['imprint.authority.label']}</p>
                <p class="legal-value">{t['imprint.authority']}</p>
              </div>
              <div>
                <p class="legal-label">{t['imprint.uid.label']}</p>
                <p class="legal-value">{t['imprint.uid']}</p>
              </div>
              <div>
                <p class="legal-label">{t['imprint.gisa.label']}</p>
                <p class="legal-value">{t['imprint.gisa']}</p>
              </div>
              <div>
                <p class="legal-label">{t['imprint.law.label']}</p>
                <p class="legal-value">{t['imprint.law']}</p>
                <p><a href="https://www.ris.bka.gv.at" target="_blank" rel="noopener noreferrer" class="legal-link legal-link--small">{t['imprint.lawlink']}</a></p>
              </div>
              <div>
                <p class="legal-label">{t['imprint.wko.label']}</p>
                <p class="legal-value">{t['imprint.wko']}</p>
              </div>
            </div>
          </section>

          <section>
            <h2 class="uc-h3 legal-section-heading">{t['imprint.editorial.heading']}</h2>
            <p class="legal-prose">{t['imprint.editorial']}</p>
            <p class="legal-prose legal-emphasis">{t['imprint.editorial.responsible']}</p>
          </section>

          <section>
            <h2 class="uc-h3 legal-section-heading">{t['imprint.liability.content.heading']}</h2>
            <p class="legal-prose">{t['imprint.liability.content']}</p>
          </section>

          <section>
            <h2 class="uc-h3 legal-section-heading">{t['imprint.liability.links.heading']}</h2>
            <p class="legal-prose">{t['imprint.liability.links']}</p>
          </section>

          <section>
            <h2 class="uc-h3 legal-section-heading">{t['imprint.copyright.heading']}</h2>
            <p class="legal-prose">{t['imprint.copyright']}</p>
          </section>

        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .legal-page {
    max-width: 880px;
    margin: 0 auto;
  }
  .legal-header {
    margin-bottom: 64px;
  }
  .legal-header .uc-h1 {
    margin-top: 16px;
  }
  .legal-subheading {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: rgb(var(--ink-muted));
    line-height: 1.6;
    margin: 24px 0 0 0;
    max-width: 65ch;
  }

  .legal-content {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .legal-section-heading {
    margin: 0 0 20px 0;
  }

  .legal-prose {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: rgb(var(--ink-muted));
    line-height: 1.65;
    margin: 0 0 12px 0;
    max-width: 65ch;
  }
  .legal-prose:last-child {
    margin-bottom: 0;
  }
  .legal-emphasis {
    color: rgb(var(--ink-primary));
    font-weight: 500;
    margin: 0;
  }

  .legal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .legal-card {
    background: rgb(var(--surface-base));
    border: 1px solid rgb(var(--ink-primary) / 0.1);
    border-radius: 8px;
    padding: 28px;
  }
  .legal-card-title {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--ink-muted));
    margin: 0 0 16px 0;
  }
  .legal-card-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: rgb(var(--ink-primary));
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  .legal-card-body p {
    margin: 0;
  }
  .legal-address {
    color: rgb(var(--ink-muted));
  }

  .legal-data-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 32px;
  }
  .legal-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--ink-muted));
    margin: 0 0 6px 0;
  }
  .legal-value {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: rgb(var(--ink-primary));
    line-height: 1.5;
    margin: 0;
  }

  .legal-link {
    color: rgb(var(--brand-primary));
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease;
  }
  .legal-link:hover {
    border-bottom-color: rgb(var(--brand-primary));
  }
  .legal-link--small {
    font-size: 0.8125rem;
  }

  @media (max-width: 700px) {
    .legal-grid,
    .legal-data-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
