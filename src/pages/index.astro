---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/HeroSection.astro';
import WhyCurfeeSection from '@/components/WhyCurfeeSection.astro';
import ObservationsSection from '@/components/ObservationsSection.astro';
import ServicesSection from '@/components/ServicesSection.astro';
import DifferentiatorSection from '@/components/DifferentiatorSection.astro';
import ConwaySection from '@/components/ConwaySection.astro';
import ContactSection from '@/components/ContactSection.astro';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();

const buildDate = new Date().toISOString().slice(0, 10);

const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://curfee.com/#services",
  "name": "Strukturarchitektur-Beratung",
  "alternateName": "Strukturarchitektur Consulting",
  "provider": { "@id": "https://curfee.com/#organization" },
  "serviceType": "Strukturarchitektur-Beratung",
  "category": ["IT-Beratung", "Unternehmensberatung", "Strukturarchitektur", "Systemarchitektur", "Softwarearchitektur", "Infrastrukturarchitektur", "Organisationsarchitektur"],
  "areaServed": [
    { "@type": "Country", "name": "Österreich" },
    { "@type": "Country", "name": "Deutschland" },
    { "@type": "Country", "name": "Schweiz" }
  ],
  "audience": {
    "@type": "BusinessAudience",
    "name": "CTOs, Engineering-Manager, Team-Leads, Gründer",
    "audienceType": "Entscheider in Unternehmen mit gewachsenen Systemlandschaften"
  },
  "serviceOutput": "Ursachenanalyse, vom System durchgesetzte Architektur-Standards über Pipelines und Werkzeuge, Governance-Rahmenwerke, Begleitung der Umsetzung",
  "availableLanguage": ["de", "en"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "@id": "https://curfee.com/#offer-catalog",
    "name": t['services.heading'],
    "itemListElement": [
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-diagnosis",
        "category": "Einstiegs-Engagement",
        "availability": "https://schema.org/InStock",
        "priceCurrency": "EUR",
        "eligibleDuration": { "@type": "QuantitativeValue", "minValue": 2, "maxValue": 4, "unitCode": "WEE" },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#diagnosis",
          "name": t['services.diagnosis.title'],
          "alternateName": ["Diagnose", "Diagnosis"],
          "description": t['services.diagnosis.problem'],
          "slogan": t['services.diagnosis.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Systemdiagnose",
          "inLanguage": ["de"]
        }
      },
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-guidance",
        "category": "Projekt-Engagement",
        "availability": "https://schema.org/InStock",
        "priceCurrency": "EUR",
        "eligibleDuration": { "@type": "QuantitativeValue", "minValue": 3, "maxValue": 6, "unitCode": "MON" },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#guidance",
          "name": t['services.guidance.title'],
          "alternateName": ["Begleitung", "Guidance"],
          "description": t['services.guidance.problem'],
          "slogan": t['services.guidance.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Architektur-Begleitung",
          "inLanguage": ["de"]
        }
      },
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-advisory",
        "category": "Retainer-Engagement",
        "availability": "https://schema.org/InStock",
        "priceCurrency": "EUR",
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#advisory",
          "name": t['services.advisory.title'],
          "alternateName": ["Architektur-Advisory", "Advisory"],
          "description": t['services.advisory.problem'],
          "slogan": t['services.advisory.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Architektur-Advisory",
          "inLanguage": ["de"]
        }
      },
    ]
  }
};

const decisionEnforcementLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "@id": "https://curfee.com/#decision-enforcement-principle",
  "name": "Prinzip der Entscheidungsdurchsetzung",
  "alternateName": ["Entscheidungsdurchsetzung", "Decision Enforcement Principle"],
  "description": "Architekturentscheidungen werden vom System selbst durchgesetzt – über Pipelines, automatisierte Checks und Tool-Konfiguration, statt durch Disziplin, Erinnerung oder Wachsamkeit einzelner Personen. Das Kernprinzip von Curfee.",
  "url": "https://curfee.com/#faq-enforcement",
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "name": "Curfee Glossar",
    "url": "https://curfee.com/llms.txt"
  },
  "subjectOf": { "@id": "https://curfee.com/#organization" },
  "author": { "@id": "https://curfee.com/#founder" }
};

const jsonLd = [serviceLd, decisionEnforcementLd];
---

<Layout
  title={t['meta.home.title']}
  description={t['meta.home.description']}
  canonicalPath={Astro.url.pathname}
  jsonLd={jsonLd}
  dateModified={buildDate}
  hasSpeakable={true}
>
  <HeroSection translations={t} />
  <WhyCurfeeSection translations={t} />
  <ObservationsSection translations={t} />
  <ServicesSection translations={t} />
  <DifferentiatorSection />
  <ConwaySection translations={t} />
  <ContactSection translations={t} />
</Layout>
