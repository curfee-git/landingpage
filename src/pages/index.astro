---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/HeroSection.astro';
import WhyCurfeeSection from '@/components/WhyCurfeeSection.astro';
import ObservationsSection from '@/components/ObservationsSection.astro';
import ServicesSection from '@/components/ServicesSection.astro';
import DifferentiatorSection from '@/components/DifferentiatorSection.astro';
import ConwaySection from '@/components/ConwaySection.astro';
import ContactSection from '@/components/ContactSection.astro';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();

const buildDate = new Date().toISOString().slice(0, 10);

const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://curfee.com/#services",
  "name": t['schema.serviceName'],
  "alternateName": t['schema.serviceAlternateName'],
  "provider": { "@id": "https://curfee.com/#organization" },
  "serviceType": t['schema.serviceType'],
  "category": t['schema.service.category'],
  "areaServed": [
    { "@type": "Country", "name": t['schema.country.austria'] },
    { "@type": "Country", "name": t['schema.country.germany'] },
    { "@type": "Country", "name": t['schema.country.switzerland'] }
  ],
  "audience": {
    "@type": "BusinessAudience",
    "name": t['schema.audienceName'],
    "audienceType": t['schema.audienceType']
  },
  "serviceOutput": t['schema.serviceOutput'],
  "availableLanguage": ["en", "de"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "@id": "https://curfee.com/#offer-catalog",
    "name": t['services.heading'],
    "itemListElement": [
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-diagnosis",
        "category": t['schema.offer.diagnosis.category'],
        "availability": "https://schema.org/InStock",
        "priceCurrency": "EUR",
        "eligibleDuration": { "@type": "QuantitativeValue", "minValue": 2, "maxValue": 4, "unitCode": "WEE" },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#diagnosis",
          "name": t['services.diagnosis.title'],
          "alternateName": ["Diagnosis"],
          "description": t['services.diagnosis.problem'],
          "slogan": t['services.diagnosis.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": t['schema.offer.diagnosis.serviceType'],
          "inLanguage": ["en"]
        }
      },
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-guidance",
        "category": t['schema.offer.guidance.category'],
        "availability": "https://schema.org/InStock",
        "priceCurrency": "EUR",
        "eligibleDuration": { "@type": "QuantitativeValue", "minValue": 3, "maxValue": 6, "unitCode": "MON" },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#guidance",
          "name": t['services.guidance.title'],
          "alternateName": ["Guidance"],
          "description": t['services.guidance.problem'],
          "slogan": t['services.guidance.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": t['schema.offer.guidance.serviceType'],
          "inLanguage": ["en"]
        }
      },
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-advisory",
        "category": t['schema.offer.advisory.category'],
        "availability": "https://schema.org/InStock",
        "priceCurrency": "EUR",
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#advisory",
          "name": t['services.advisory.title'],
          "alternateName": ["Architecture Advisory", "Advisory"],
          "description": t['services.advisory.problem'],
          "slogan": t['services.advisory.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": t['schema.offer.advisory.serviceType'],
          "inLanguage": ["en"]
        }
      },
    ]
  }
};

const decisionEnforcementLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "@id": "https://curfee.com/#decision-enforcement-principle",
  "name": t['schema.decisionEnforcement.name'],
  "alternateName": ["Decision Enforcement", "Decision Enforcement Principle"],
  "description": t['schema.decisionEnforcement.description'],
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "name": t['schema.glossaryName'],
    "url": "https://curfee.com/llms.txt"
  },
  "subjectOf": { "@id": "https://curfee.com/#organization" },
  "author": { "@id": "https://curfee.com/#founder" }
};

const jsonLd = [serviceLd, decisionEnforcementLd];
---

<Layout
  title={t['meta.home.title']}
  description={t['meta.home.description']}
  canonicalPath={Astro.url.pathname}
  jsonLd={jsonLd}
  dateModified={buildDate}
  hasSpeakable={true}
>
  <HeroSection translations={t} />
  <WhyCurfeeSection translations={t} />
  <ObservationsSection translations={t} />
  <ServicesSection translations={t} />
  <DifferentiatorSection />
  <ConwaySection translations={t} />
  <ContactSection translations={t} />
</Layout>
