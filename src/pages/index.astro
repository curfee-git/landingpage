---
// Root entry: detect preferred locale (localStorage > navigator.language > en)
// and redirect. Logic lives in src/scripts/locale-detect.ts.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Curfee</title>
    <link rel="canonical" href="https://curfee.com/en/" />
    <link rel="alternate" hreflang="en" href="https://curfee.com/en/" />
    <link rel="alternate" hreflang="de-AT" href="https://curfee.com/de/" />
    <link rel="alternate" hreflang="x-default" href="https://curfee.com/en/" />
    <noscript>
      <meta http-equiv="refresh" content="0;url=/en/" />
    </noscript>
    <script>
      import { redirectToPreferredLocale } from '@/scripts/locale-detect';
      redirectToPreferredLocale();
    </script>
  </head>
  <body>
    <p style="font-family:system-ui,sans-serif;padding:2rem;">
      Loading… <a href="/en/">English</a> · <a href="/de/">Deutsch</a>
    </p>
  </body>
</html>
