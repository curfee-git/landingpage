---
import Layout from '@/layouts/Layout.astro';
import { getRoutes } from '@/configurations/routes';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();
const routes = getRoutes();
---

<Layout
  title={t['meta.404.title']}
  description={t['meta.404.description']}
  canonicalPath={Astro.url.pathname}
  noindex={true}
>
  <article class="cf-section error-page">
    <div class="cf-container">
      <div class="error-inner">
        <p class="error-code" aria-hidden="true">404</p>
        <h1 class="error-heading">{t['404.heading']}</h1>
        <p class="error-description">{t['404.description']}</p>
        <a href={routes.home} class="cf-btn cf-btn--primary error-cta">{t['404.cta']}</a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .error-page {
    padding-top: clamp(56px, 6vw, 96px);
    padding-bottom: clamp(80px, 9vw, 128px);
  }
  .error-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .error-code {
    font-family: var(--font-sans);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: rgb(var(--brand-primary));
    margin: 0 0 8px 0;
    user-select: none;
  }
  .error-heading {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: rgb(var(--ink-primary));
    margin: 0;
    text-wrap: balance;
  }
  .error-description {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: rgb(var(--ink-primary) / 0.75);
    line-height: 1.6;
    margin: 16px auto 0 auto;
    max-width: 480px;
  }
  .error-cta {
    margin-top: 32px;
  }
</style>
