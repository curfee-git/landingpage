---
import Layout from '@/layouts/Layout.astro';
import { getTranslations } from '@/i18n/translations';

// Root 404: GitHub Pages serves /404.html for ANY 404 regardless of URL path.
// Render English content as the SEO/no-JS fallback. Inline script below
// detects DE (via current pathname or localStorage.curfee_lang) and
// redirects to /de/404/ so DE users see the localized 404.
const t = getTranslations('en');
---

<Layout title={t['meta.404.title']} description={t['meta.404.description']} canonicalPath="/404" noindex={true}>
  <script>
    import { redirectIfDeLocale } from '@/scripts/locale-404-redirect';
    redirectIfDeLocale();
  </script>

  <article class="uc-section error-page">
    <div class="uc-container">
      <div class="error-inner">
        <p class="error-code" aria-hidden="true">404</p>
        <h1 class="error-heading">{t['404.heading']}</h1>
        <p class="error-description">{t['404.description']}</p>
        <a href="/en/" class="uc-btn uc-btn--primary error-cta">{t['404.cta']}</a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .error-page {
    padding-top: clamp(56px, 6vw, 96px);
    padding-bottom: clamp(80px, 9vw, 128px);
  }
  .error-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .error-code {
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: rgb(var(--brand-primary) / 0.2);
    margin: 0 0 8px 0;
    user-select: none;
  }
  .error-heading {
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: rgb(var(--ink-primary));
    margin: 0;
    text-wrap: balance;
  }
  .error-description {
    font-size: 1rem;
    color: rgb(var(--ink-muted));
    line-height: 1.6;
    margin: 16px auto 0 auto;
    max-width: 480px;
  }
  .error-cta {
    margin-top: 32px;
  }
</style>
