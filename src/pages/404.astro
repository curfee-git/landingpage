---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/shared/Icon.astro';
import { getTranslations } from '@/i18n/translations';

// Root 404: GitHub Pages serves /404.html for ANY 404 regardless of URL path.
// Render English content as the SEO/no-JS fallback. Inline script below
// detects DE (via current pathname or localStorage.curfee_lang) and
// redirects to /de/404/ so DE users see the localized 404.
const t = getTranslations('en');
---

<Layout title={t['meta.404.title']} description={t['meta.404.description']} canonicalPath="/404" noindex={true}>
  <script>
    import { redirectIfDeLocale } from '@/scripts/locale-404-redirect';
    redirectIfDeLocale();
  </script>

  <div class="min-h-[75vh] flex items-center justify-center px-6" style="background: linear-gradient(to bottom, rgb(var(--brand-primary) / 0) 0%, rgb(var(--brand-primary) / 0.05) 50%, rgb(var(--brand-primary) / 0.05) 100%);">
    <div class="text-center max-w-lg">
      <span class="text-display-large text-brand-primary/15 block mb-2 select-none">404</span>
      <h1 class="text-headline-large text-ink-primary mb-3">{t['404.heading']}</h1>
      <p class="text-body-large text-ink-muted mb-12">{t['404.description']}</p>
      <a href="/en/" class="inline-flex items-center gap-2 px-8 py-3 rounded-full bg-brand-primary text-brand-onPrimary text-label-large font-medium shadow-elevation-0 hover:shadow-elevation-1 active:shadow-elevation-0 transition-all duration-medium2 ease-standard">
        <Icon name="arrow_back" class="w-5 h-5" />
        {t['404.cta']}
      </a>
    </div>
  </div>
</Layout>
