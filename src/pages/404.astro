---
import Layout from '@/layouts/Layout.astro';
import { getRoutes } from '@/configurations/routes';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();
const routes = getRoutes();
---

<Layout
  title={t['meta.404.title']}
  description={t['meta.404.description']}
  canonicalPath={Astro.url.pathname}
  noindex={true}
>
  <article class="pt-14 sm:pt-20 xl:pt-24 pb-20 sm:pb-28 xl:pb-32">
    <div class="max-w-[1200px] mx-auto px-[var(--gutter)] xl:px-0">
      <div class="max-w-[720px] mx-auto text-center">
        <p
          class="font-sans text-[clamp(3.5rem,8vw,6rem)] font-extrabold leading-[0.95] tracking-[-0.03em] text-brand-primary m-0 mb-2 select-none"
          aria-hidden="true"
        >404</p>
        <h1 class="font-sans text-[clamp(1.5rem,3vw,2rem)] font-extrabold leading-[1.2] tracking-[-0.015em] text-ink-primary m-0 text-balance">
          {t['404.heading']}
        </h1>
        <p class="font-sans text-base text-ink-muted leading-[1.6] mt-4 mx-auto max-w-[480px]">
          {t['404.description']}
        </p>
        <a
          href={routes.home}
          class="inline-flex items-center justify-center mt-8 px-6 py-3.5 font-sans text-[0.9375rem] font-bold rounded-md no-underline border-[1.5px] transition-colors duration-200 bg-brand-primary text-brand-onPrimary border-brand-primary hover:bg-[#002952] hover:border-[#002952]"
        >
          {t['404.cta']}
        </a>
      </div>
    </div>
  </article>
</Layout>
